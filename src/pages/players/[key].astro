---
import Layout from "../../layouts/Layout.astro";
import { BATTING_SPECS, percentile, percentileColor } from "../../lib/percentiles";

export async function getStaticPaths() {
  const modules = import.meta.glob("../../content/players/*.json", { eager: true });
  return Object.values(modules).map((m: any) => ({
    params: { key: m.default.key },
    props: { player: m.default },
  }));
}

const { player } = Astro.props;
const hitting = player.basic?.hitting;
const pitching = player.basic?.pitching;
const savantHit = player.savant?.hitting;
const arsenal = player.savant?.pitch_arsenal;

const typeCode = { two_way: "二刀流", batter: "野手", pitcher: "投手" }[player.type] ?? player.type;
let leagueLabel: string;
if (player.level === "AAA") leagueLabel = "3A";
else if (player.level === "FORMER") leagueLabel = "元MLB";
else leagueLabel = (({ NL: "ナ・リーグ", AL: "ア・リーグ" } as Record<string, string>)[player.league] ?? player.league);

const isFormer = player.level === "FORMER";
const summarySubtitle = isFormer
  ? `MLB通算 · ${player.mlb_years ?? ""}`
  : (hitting ? "打撃 · 2026" : "投手 · 2026");

// Build percentile rows from savant hitting data
const percentileMetrics = savantHit ? [
  { key: "exit_velocity_avg", label: "打球速度", labelEn: "Exit Velocity", value: savantHit.exit_velocity_avg, fmt: (v: number) => `${v} mph` },
  { key: "barrel_batted_rate", label: "Barrel率", labelEn: "Barrel %", value: savantHit.barrel_batted_rate, fmt: (v: number) => `${v}%` },
  { key: "hard_hit_percent", label: "Hard-Hit率", labelEn: "Hard-Hit %", value: savantHit.hard_hit_percent, fmt: (v: number) => `${v}%` },
  { key: "xba", label: "xBA", labelEn: "xBA", value: savantHit.xba, fmt: (v: string) => v },
  { key: "xslg", label: "xSLG", labelEn: "xSLG", value: savantHit.xslg, fmt: (v: string) => v },
  { key: "xwoba", label: "xwOBA", labelEn: "xwOBA", value: savantHit.xwoba, fmt: (v: string) => v },
  { key: "k_percent", label: "K率", labelEn: "K %", value: savantHit.k_percent, fmt: (v: number) => `${v}%` },
  { key: "bb_percent", label: "BB率", labelEn: "BB %", value: savantHit.bb_percent, fmt: (v: number) => `${v}%` },
].map((m) => {
  const spec = BATTING_SPECS[m.key];
  const pct = spec ? percentile(m.value, spec) : 50;
  return { ...m, pct };
}) : [];

// Pitch colors by code
const pitchColors: Record<string, string> = {
  FF: "var(--pitch-ff)", FT: "var(--pitch-ft)", FS: "var(--pitch-fs)", FC: "var(--pitch-fc)",
  SI: "var(--pitch-si)", SL: "var(--pitch-sl)", CU: "var(--pitch-cu)", CH: "var(--pitch-ch)", KC: "var(--pitch-kc)",
};

// Yearly stats split by type (handles two_way correctly)
const yearly = player.yearly ?? [];
const hittingYearly = yearly.filter((y: any) => y.type === "hit");
const pitchingYearly = yearly.filter((y: any) => y.type === "pit");

// Career-high ranks (rank 1 = career best)
const hitCareerRanks = {
  avg: rankYears(hittingYearly, "avg", true),
  h: rankYears(hittingYearly, "h", true),
  hr: rankYears(hittingYearly, "hr", true),
  rbi: rankYears(hittingYearly, "rbi", true),
  sb: rankYears(hittingYearly, "sb", true),
  obp: rankYears(hittingYearly, "obp", true),
  slg: rankYears(hittingYearly, "slg", true),
  ops: rankYears(hittingYearly, "ops", true),
};
const pitCareerRanks = {
  w: rankYears(pitchingYearly, "w", true),
  l: rankYears(pitchingYearly, "l", false), // fewer losses = better
  era: rankYears(pitchingYearly, "era", false),
  so: rankYears(pitchingYearly, "so", true),
  ip: rankYears(pitchingYearly, "ip", true),
  whip: rankYears(pitchingYearly, "whip", false),
  sv: rankYears(pitchingYearly, "sv", true),
  hld: rankYears(pitchingYearly, "hld", true),
};

// Highlight class based on MLB league/league-wide rank
// led: led MLB or AL/NL that year
// top10: top 10 in MLB that year
// Career rank: lower number = better (rank 1 = career high)
function rankYears(rows: any[], field: string, higherBetter: boolean) {
  if (!rows.length) return [];
  const values = rows.map((r, i) => ({ i, v: parseFloat(r[field]) }));
  // Treat NaN/0 IP rows as worst
  values.sort((a, b) => {
    const av = isNaN(a.v) ? -Infinity : a.v;
    const bv = isNaN(b.v) ? -Infinity : b.v;
    return higherBetter ? bv - av : av - bv;
  });
  const ranks: number[] = new Array(rows.length).fill(0);
  values.forEach((item, idx) => { ranks[item.i] = idx + 1; });
  return ranks;
}

function statClass(row: any, field: string, careerRank?: number): string {
  if (row.led && row.led.includes(field)) return "rank-1";
  if (row.top10 && row.top10.includes(field)) return "rank-top";
  if (careerRank === 1) return "career-high";
  return "";
}

const STAT_LABEL_JP: Record<string, string> = {
  avg: "打率", h: "安打", hr: "本塁打", rbi: "打点", sb: "盗塁", ops: "OPS",
  era: "防御率", w: "勝", l: "敗", so: "奪三振", ip: "投球回", whip: "WHIP",
};

// Collect MLB-leading seasons across all yearly rows
const ledSeasons = yearly
  .filter((y: any) => y.led && y.led.length > 0)
  .map((y: any) => ({
    year: y.year, team: y.team, type: y.type,
    items: y.led.map((field: string) => ({ field, value: y[field], label: STAT_LABEL_JP[field] ?? field })),
  }));

// Awards: group by category, count repeats
const allAwards = (player.awards ?? []) as Array<{year: number; label: string; cat: string}>;
type AwardGroup = { label: string; cat: string; count: number; years: number[] };
const awardsByCat: Map<string, AwardGroup> = new Map();
for (const a of allAwards) {
  const key = a.cat;
  const g = awardsByCat.get(key);
  if (g) { g.count++; g.years.push(a.year); }
  else { awardsByCat.set(key, { label: a.label, cat: a.cat, count: 1, years: [a.year] }); }
}
// Display order — top tier first
const CAT_ORDER = ["ws-mvp", "mvp", "cy", "roy", "alcs-mvp", "nlcs-mvp", "silver", "gold", "aaron", "comeback", "historic", "as"];
const groupedAwards = Array.from(awardsByCat.values())
  .sort((a, b) => CAT_ORDER.indexOf(a.cat) - CAT_ORDER.indexOf(b.cat));

// JSON-LD: Person + BreadcrumbList
const playerJsonLd: object[] = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": player.name_jp,
    "alternateName": player.name_en,
    "url": `https://sakuraballpark.com/players/${player.key}/`,
    "jobTitle": player.position_jp,
    "affiliation": isFormer ? undefined : {
      "@type": "SportsTeam",
      "name": player.team_jp,
      "alternateName": player.team_en,
    },
    "nationality": "Japan",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://sakuraballpark.com/" },
      { "@type": "ListItem", "position": 2, "name": "選手", "item": "https://sakuraballpark.com/#players" },
      { "@type": "ListItem", "position": 3, "name": player.name_jp, "item": `https://sakuraballpark.com/players/${player.key}/` },
    ],
  },
];
---
<Layout
  title={player.name_jp}
  description={`${player.name_jp}（${player.team_jp}）の${isFormer ? "MLB通算成績" : "2026シーズン成績"}・年度別データ・受賞歴`}
  lang="ja"
  currentPath={`/players/${player.key}/`}
  ogType="profile"
  jsonLd={playerJsonLd}
  modifiedDate={player.updated_at}
>
  <nav class="breadcrumb"><a href="/">← ホーム</a> <span class="sep">/</span> <span>選手</span> <span class="sep">/</span> <span class="current">{player.name_jp}</span></nav>

  <header class="player-hero">
    <div class="hero-tags">
      <span class={`tag type type-${player.type}`}>{typeCode}</span>
      <span class:list={["tag league", `league-${player.league.toLowerCase()}`, { former: isFormer }]}>{leagueLabel}</span>
    </div>
    <h1 class="player-name">{player.name_jp}</h1>
    <div class="player-meta">
      <span class="team">{isFormer ? `${player.team_jp} (元所属)` : player.team_jp}</span>
      <span class="sep">·</span>
      <span class="pos">{player.position_jp}</span>
    </div>
    {isFormer && (
      <div class="former-info">
        <div class="former-row"><span class="former-lbl">MLB在籍</span><span class="former-val mono">{player.mlb_years}</span></div>
        <div class="former-row"><span class="former-lbl">現状</span><span class="former-val">{player.current_status_jp}</span></div>
      </div>
    )}
  </header>

  {isFormer && (
    <div class="career-banner">
      <span class="banner-label">MLB通算成績</span>
      <span class="banner-years mono">{player.mlb_years}</span>
    </div>
  )}

  {groupedAwards.length > 0 && (
    <section class="awards-panel">
      <div class="awards-head">
        <span class="awards-icon" aria-hidden="true">🏅</span>
        <h2>受賞歴</h2>
        <span class="awards-count">{allAwards.length}件</span>
      </div>
      <div class="awards-grid">
        {groupedAwards.map((g) => (
          <div class={"award-card cat-" + g.cat}>
            <div class="award-label">{g.label}</div>
            <div class="award-meta">
              {g.count > 1 && <span class="award-count">{g.count}回</span>}
              <span class="award-years mono">
                {g.years.length <= 3
                  ? g.years.join(", ")
                  : Math.min(...g.years) + "–" + Math.max(...g.years)}
              </span>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {ledSeasons.length > 0 && (
    <section class="led-panel">
      <div class="led-head">
        <span class="led-icon" aria-hidden="true">🏆</span>
        <h2>MLB全体一位スタッツ</h2>
        <span class="led-count">{ledSeasons.reduce((s: number, x: any) => s + x.items.length, 0)}回</span>
      </div>
      <div class="led-list">
        {ledSeasons.map((s: any) => (
          <div class="led-row">
            <div class="led-year mono">{s.year}</div>
            <div class="led-team mono">{s.team}</div>
            <div class="led-items">
              {s.items.map((it: any) => (
                <span class="led-item">
                  <span class="led-label">{it.label}</span>
                  <span class="led-value mono">{it.value}</span>
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- SUMMARY ROW: Big primary stats -->
  {hitting && (
    <section class="summary-row">
      <div class="summary-card primary">
        <div class="sc-label">打率</div>
        <div class="sc-value mono">{hitting.avg}</div>
      </div>
      {hitting.h !== undefined && (
        <div class="summary-card">
          <div class="sc-label">安打</div>
          <div class="sc-value mono">{hitting.h}</div>
        </div>
      )}
      <div class="summary-card">
        <div class="sc-label">本塁打</div>
        <div class="sc-value mono">{hitting.hr}</div>
      </div>
      <div class="summary-card">
        <div class="sc-label">打点</div>
        <div class="sc-value mono">{hitting.rbi}</div>
      </div>
      <div class="summary-card">
        <div class="sc-label">出塁率</div>
        <div class="sc-value mono">{hitting.obp}</div>
      </div>
      {hitting.slg !== undefined && (
        <div class="summary-card">
          <div class="sc-label">長打率</div>
          <div class="sc-value mono">{hitting.slg}</div>
        </div>
      )}
      <div class="summary-card primary">
        <div class="sc-label">OPS</div>
        <div class="sc-value mono">{hitting.ops}</div>
      </div>
      <div class="summary-card">
        <div class="sc-label">盗塁</div>
        <div class="sc-value mono">{hitting.sb}</div>
      </div>
    </section>
  )}

  {pitching && (
    <section class="summary-row">
      <div class="summary-card primary">
        <div class="sc-label">防御率</div>
        <div class="sc-value mono">{pitching.era}</div>
      </div>
      <div class="summary-card">
        <div class="sc-label">勝敗</div>
        <div class="sc-value mono">{pitching.w}-{pitching.l}</div>
      </div>
      {pitching.sv !== undefined && (
        <div class="summary-card">
          <div class="sc-label">セーブ</div>
          <div class="sc-value mono">{pitching.sv}</div>
        </div>
      )}
      {pitching.hld !== undefined && (
        <div class="summary-card">
          <div class="sc-label">ホールド</div>
          <div class="sc-value mono">{pitching.hld}</div>
        </div>
      )}
      <div class="summary-card primary">
        <div class="sc-label">奪三振</div>
        <div class="sc-value mono">{pitching.so}</div>
      </div>
      <div class="summary-card">
        <div class="sc-label">WHIP</div>
        <div class="sc-value mono">{pitching.whip}</div>
      </div>
      <div class="summary-card">
        <div class="sc-label">投球回</div>
        <div class="sc-value mono">{pitching.ip}</div>
      </div>
    </section>
  )}

  {hittingYearly.length > 0 && (
    <section class="panel">
      <div class="panel-head">
        <h2>年度別成績{pitchingYearly.length > 0 ? "(打撃)" : ""}</h2>
        <span class="panel-sub">{player.mlb_years ?? ""}</span>
      </div>
      <div class="yearly-wrap">
        <table class="yearly-table">
          <thead>
            <tr>
              <th class="num">年</th>
              <th>チーム</th>
              <th class="num">打率</th>
              <th class="num">安打</th>
              <th class="num">本塁打</th>
              <th class="num">打点</th>
              <th class="num">盗塁</th>
              {hittingYearly.some((y: any) => y.obp) && <th class="num">出塁率</th>}
              {hittingYearly.some((y: any) => y.slg) && <th class="num">長打率</th>}
              <th class="num">OPS</th>
            </tr>
          </thead>
          <tbody>
            {hittingYearly.map((y: any, i: number) => (
              <tr>
                <td class="num mono">{y.year}</td>
                <td class="mono">{y.team}</td>
                <td class:list={["num", "mono", statClass(y, "avg", hitCareerRanks.avg[i])]}>{y.avg}</td>
                <td class:list={["num", "mono", statClass(y, "h", hitCareerRanks.h[i])]}>{y.h}</td>
                <td class:list={["num", "mono", statClass(y, "hr", hitCareerRanks.hr[i])]}>{y.hr}</td>
                <td class:list={["num", "mono", statClass(y, "rbi", hitCareerRanks.rbi[i])]}>{y.rbi}</td>
                <td class:list={["num", "mono", statClass(y, "sb", hitCareerRanks.sb[i])]}>{y.sb}</td>
                {hittingYearly.some((r: any) => r.obp) && <td class:list={["num", "mono", statClass(y, "obp", hitCareerRanks.obp[i])]}>{y.obp ?? "—"}</td>}
                {hittingYearly.some((r: any) => r.slg) && <td class:list={["num", "mono", statClass(y, "slg", hitCareerRanks.slg[i])]}>{y.slg ?? "—"}</td>}
                <td class:list={["num", "mono", statClass(y, "ops", hitCareerRanks.ops[i])]}>{y.ops}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="rank-legend">
        <span class="legend-item"><span class="legend-swatch career-high"></span>キャリアハイ</span>
        <span class="legend-item"><span class="legend-swatch rank-top"></span>MLB10位以内</span>
        <span class="legend-item"><span class="legend-swatch rank-1"></span><strong>MLB1位</strong></span>
      </div>
    </section>
  )}

  {pitchingYearly.length > 0 && (
    <section class="panel">
      <div class="panel-head">
        <h2>年度別成績{hittingYearly.length > 0 ? "(投手)" : ""}</h2>
        <span class="panel-sub">{player.mlb_years ?? ""}</span>
      </div>
      <div class="yearly-wrap">
        <table class="yearly-table">
          <thead>
            <tr>
              <th class="num">年</th>
              <th>チーム</th>
              <th class="num">勝</th>
              <th class="num">敗</th>
              <th class="num">防御率</th>
              <th class="num">奪三振</th>
              <th class="num">投球回</th>
              <th class="num">WHIP</th>
              {pitchingYearly.some((y: any) => y.sv !== undefined) && <th class="num">セーブ</th>}
              {pitchingYearly.some((y: any) => y.hld !== undefined) && <th class="num">ホールド</th>}
            </tr>
          </thead>
          <tbody>
            {pitchingYearly.map((y: any, i: number) => (
              <tr>
                <td class="num mono">{y.year}</td>
                <td class="mono">{y.team}</td>
                <td class:list={["num", "mono", statClass(y, "w", pitCareerRanks.w[i])]}>{y.w}</td>
                <td class:list={["num", "mono", statClass(y, "l", pitCareerRanks.l[i])]}>{y.l}</td>
                <td class:list={["num", "mono", statClass(y, "era", pitCareerRanks.era[i])]}>{y.era}</td>
                <td class:list={["num", "mono", statClass(y, "so", pitCareerRanks.so[i])]}>{y.so}</td>
                <td class:list={["num", "mono", statClass(y, "ip", pitCareerRanks.ip[i])]}>{y.ip}</td>
                <td class:list={["num", "mono", statClass(y, "whip", pitCareerRanks.whip[i])]}>{y.whip}</td>
                {pitchingYearly.some((r: any) => r.sv !== undefined) && <td class:list={["num", "mono", statClass(y, "sv", pitCareerRanks.sv[i])]}>{y.sv ?? "—"}</td>}
                {pitchingYearly.some((r: any) => r.hld !== undefined) && <td class:list={["num", "mono", statClass(y, "hld", pitCareerRanks.hld[i])]}>{y.hld ?? "—"}</td>}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {!hittingYearly.length && (
        <div class="rank-legend">
          <span class="legend-item"><span class="legend-swatch rank-1"></span>キャリア1位</span>
          <span class="legend-item"><span class="legend-swatch rank-top"></span>10位以内</span>
        </div>
      )}
    </section>
  )}

  <!-- PERCENTILE RANKINGS: Savant hallmark -->
  {/* Batting Statcast percentile panel removed: requires Baseball Savant data
      which is not freely available via API. Re-enable once a verified data source
      is configured. */}

  <!-- PITCH ARSENAL -->
  {arsenal && arsenal.length > 0 && (
    <section class="panel">
      <div class="panel-head">
        <h2>球種別データ</h2>
        <span class="panel-sub">{player.savant?.arsenal_season ?? 2026}シーズン · 使用率・平均球速 (MLB Stats API)</span>
      </div>
      <table class="arsenal-table">
        <thead>
          <tr>
            <th>球種</th>
            <th class="num">使用率</th>
            <th class="dist">使用率分布</th>
            <th class="num">平均球速 (mph)</th>
          </tr>
        </thead>
        <tbody>
          {arsenal.map((a: any) => (
            <tr>
              <td>
                <div class="pitch-cell">
                  <span class="pitch-dot" style={`background: ${pitchColors[a.pitch] ?? "var(--pitch-default)"}`}></span>
                  <div>
                    <div class="pitch-name">{a.jp}</div>
                    <div class="pitch-sub mono">{a.pitch}</div>
                  </div>
                </div>
              </td>
              <td class="num mono">{a.usage}%</td>
              <td class="dist">
                <div class="dist-bars">
                  <div class="dist-bar" style={`--w: ${Math.min(a.usage, 100)}%; --c: ${pitchColors[a.pitch] ?? "var(--pitch-default)"}`} title={`Usage ${a.usage}%`}></div>
                </div>
              </td>
              <td class="num mono">{a.speed ? a.speed.toFixed(1) : "—"}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  <div class="footer-meta">最終更新 · <span class="mono">{player.updated_at}</span>{isFormer && <span class="mono"> · MLB career stats</span>}</div>
</Layout>

<style>
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
    display: flex; gap: 0.5rem; align-items: center;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--text-muted); }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb .sep { color: var(--text-dim); }
  .breadcrumb .current { color: var(--text); font-weight: 600; }

  /* Hero */
  .player-hero {
    padding: 2rem 0 2rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2rem;
  }
  .hero-tags { display: flex; gap: 0.4rem; margin-bottom: 0.8rem; }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.65rem; font-weight: 600;
    letter-spacing: 0.1em;
    padding: 0.22rem 0.55rem;
    border-radius: var(--radius-sm);
  }
  .tag.type { background: rgba(214, 37, 56, 0.08); color: var(--sv-red); border: 1px solid rgba(214, 37, 56, 0.2); }
  .tag.type.type-two_way { background: linear-gradient(90deg, rgba(214, 37, 56, 0.1), rgba(237, 124, 44, 0.1)); color: var(--sv-orange); border-color: rgba(237, 124, 44, 0.25); }
  .tag.league { background: var(--surface-3); color: var(--text-muted); border: 1px solid var(--border); }
  .tag.league.league-nl { color: var(--sv-blue); border-color: rgba(44, 93, 209, 0.25); background: rgba(44, 93, 209, 0.06); }
