---
import Layout from "../layouts/Layout.astro";
import PlayerCard from "../components/PlayerCard.astro";
import ohtani from "../content/players/ohtani.json";
import imanaga from "../content/players/imanaga.json";
import murakami from "../content/players/murakami.json";

const players = [ohtani, imanaga, murakami];

const articleModules = import.meta.glob("../content/articles/*.json", { eager: true });
const articles = Object.values(articleModules)
  .map((m: any) => m.default)
  .sort((a: any, b: any) => (a.date < b.date ? 1 : -1));
const featured = articles.slice(0, 4);
---
<Layout title="SakuraBall" description="日本人メジャーリーガーのシーズン成績、Statcast指標、最新分析記事を掲載" lang="ja" currentPath="/">
  <section class="hero">
    <div class="hero-eyebrow">2026 SEASON</div>
    <h1 class="hero-title">日本人メジャーリーガーを<br />データで読む。</h1>
    <p class="hero-lede">
      シーズン成績・Statcast 指標・球種別分析を一箇所に。
      大谷翔平の二刀流から、村上宗隆の MLB 適応、今永昇太の球種戦略まで。
    </p>
    <div class="hero-cta">
      <a class="btn btn-primary" href="#players">選手を見る</a>
      <a class="btn btn-ghost" href="/articles/">記事を読む</a>
    </div>
  </section>

  <section id="players" class="section">
    <div class="section-header">
      <h2>注目の選手</h2>
      <span class="section-count">{players.length}名</span>
    </div>
    <div class="player-grid">
      {players.map((p) => (
        <PlayerCard player={p} lang="ja" href={`/players/${p.key}/`} />
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>最新の記事</h2>
      <a class="section-more" href="/articles/">すべて見る →</a>
    </div>
    <div class="article-grid">
      {featured.map((a: any) => (
        <a class="article-tile" href={`/articles/${a.slug}/`}>
          <div class="tile-meta">
            <span class="tile-date">{a.date}</span>
            <span class="tile-cat">{a.category}</span>
          </div>
          <div class="tile-title">{a.title_jp}</div>
          <div class="tile-summary">{a.summary_jp}</div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 3rem 0 2.5rem;
    text-align: center;
  }
  .hero-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: var(--accent);
    background: var(--rose-100);
    padding: 0.3rem 0.9rem;
    border-radius: 100px;
    margin-bottom: 1.4rem;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4.5vw, 2.8rem);
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 1.2rem;
    color: var(--text);
    letter-spacing: -0.02em;
  }
  .hero-lede {
    max-width: 580px;
    margin: 0 auto 2rem;
    font-size: 1.02rem;
    color: var(--text-muted);
    line-height: 1.85;
  }
  .hero-cta {
    display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap;
  }
  .btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 0.75rem 1.6rem;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 100px;
    transition: all 0.18s ease;
  }
  .btn-primary {
    background: var(--accent);
    color: white;
    box-shadow: 0 4px 14px rgba(200, 81, 110, 0.3);
  }
  .btn-primary:hover {
    background: var(--rose-600); color: white; text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(200, 81, 110, 0.4);
  }
  .btn-ghost {
    color: var(--text);
    border: 1px solid var(--rose-200);
    background: rgba(255, 255, 255, 0.5);
  }
  .btn-ghost:hover { background: var(--rose-100); text-decoration: none; }

  /* Section */
  .section { margin-top: 3.5rem; }
  .section-header {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: 1.4rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--border);
  }
  .section-header h2 {
    font-size: 1.4rem; font-weight: 700; margin: 0;
    color: var(--text);
  }
  .section-count {
    font-size: 0.85rem; color: var(--text-muted);
  }
  .section-more {
    font-size: 0.9rem;
    font-weight: 500;
  }

  .player-grid { display: grid; gap: 0.85rem; }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.85rem;
  }
  .article-tile {
    display: flex; flex-direction: column; gap: 0.5rem;
    padding: 1.1rem 1.2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    color: var(--text);
    box-shadow: var(--shadow-sm);
    transition: all 0.18s ease;
  }
  .article-tile:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--rose-200);
    text-decoration: none;
  }
  .tile-meta {
    display: flex; gap: 0.5rem; align-items: center;
    font-size: 0.75rem;
  }
  .tile-date { color: var(--text-muted); font-variant-numeric: tabular-nums; }
  .tile-cat {
    background: var(--rose-100); color: var(--rose-700);
    padding: 0.1rem 0.55rem; border-radius: 100px;
    font-weight: 600; letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 0.65rem;
  }
  .tile-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.45;
    color: var(--text);
  }
  .tile-summary {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
