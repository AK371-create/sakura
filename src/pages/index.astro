---
import Layout from "../layouts/Layout.astro";
import PlayerCard from "../components/PlayerCard.astro";
import ohtani from "../content/players/ohtani.json";
import imanaga from "../content/players/imanaga.json";
import murakami from "../content/players/murakami.json";

const players = [ohtani, imanaga, murakami];

const articleModules = import.meta.glob("../content/articles/*.json", { eager: true });
const articles = Object.values(articleModules)
  .map((m: any) => m.default)
  .sort((a: any, b: any) => (a.date < b.date ? 1 : -1));
const featured = articles.slice(0, 6);

const categoryLabels: Record<string, string> = {
  player: "選手", statcast: "Statcast", history: "歴史", rivalry: "対戦",
  rules: "ルール", team: "チーム", prospects: "若手", culture: "文化", market: "市場",
};

const stats = {
  players: players.length,
  articles: articles.length,
  lastUpdate: articles[0]?.date ?? "",
};
---
<Layout title="SakuraBall" description="日本人メジャーリーガーのシーズン成績、Statcast指標、分析記事" lang="ja" currentPath="/">
  <section class="hero">
    <div class="hero-eyebrow mono">日本人メジャーリーガー / 2026シーズン</div>
    <h1 class="hero-title">日本人MLB、<br /><span class="accent">データで読む。</span></h1>
    <p class="hero-lede">
      Statcast指標、球種別成績、パーセンタイルで日本人メジャーリーガーを解剖する。
    </p>
    <div class="hero-stats">
      <div class="hstat">
        <div class="hstat-val mono">{stats.players}</div>
        <div class="hstat-lbl">選手</div>
      </div>
      <div class="hstat">
        <div class="hstat-val mono">{stats.articles}</div>
        <div class="hstat-lbl">記事</div>
      </div>
      <div class="hstat">
        <div class="hstat-val mono">{stats.lastUpdate}</div>
        <div class="hstat-lbl">最終更新</div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div class="section-head-main">
        <span class="section-num mono">01</span>
        <h2>選手</h2>
      </div>
      <span class="mono section-count">{players.length}名</span>
    </div>
    <div class="player-grid">
      {players.map((p) => (
        <PlayerCard player={p} lang="ja" href={`/players/${p.key}/`} />
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div class="section-head-main">
        <span class="section-num mono">02</span>
        <h2>記事</h2>
      </div>
      <a class="section-link" href="/articles/">すべて見る →</a>
    </div>
    <div class="article-grid">
      {featured.map((a: any) => (
        <a class="article-tile" href={`/articles/${a.slug}/`}>
          <div class="tile-meta">
            <span class="tile-cat">{categoryLabels[a.category] ?? a.category}</span>
            <span class="tile-date mono">{a.date}</span>
          </div>
          <div class="tile-title">{a.title_jp}</div>
          <div class="tile-summary">{a.summary_jp}</div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 3rem 0 2.5rem;
    margin-bottom: 1rem;
  }
  .hero-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.2em;
    margin-bottom: 1.2rem;
  }
  .hero-title {
    font-size: clamp(2.2rem, 5.5vw, 3.8rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 1.2rem;
  }
  .hero-title .accent { color: var(--accent); }
  .hero-lede {
    max-width: 560px;
    font-size: 1.02rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0 0 2rem;
  }
  .hero-stats {
    display: flex; gap: 2rem; flex-wrap: wrap;
    padding: 1.2rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .hstat { display: flex; flex-direction: column; gap: 0.25rem; }
  .hstat-val {
    font-size: 1.5rem; font-weight: 700;
    color: var(--text);
    line-height: 1;
    font-feature-settings: "tnum" 1;
  }
  .hstat-lbl {
    font-size: 0.72rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  /* Section */
  .section { margin-top: 3rem; }
  .section-head {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-bottom: 1.2rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--border);
  }
  .section-head-main { display: flex; align-items: baseline; gap: 0.7rem; }
  .section-num {
    font-size: 0.8rem;
    color: var(--text-dim);
    letter-spacing: 0.08em;
  }
  .section-head h2 {
    font-size: 1.3rem; font-weight: 700; margin: 0;
    letter-spacing: -0.01em;
  }
  .section-count { font-size: 0.7rem; color: var(--text-dim); letter-spacing: 0.08em; }
  .section-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
  }
  .section-link:hover { color: var(--accent); text-decoration: none; }

  .player-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 0.8rem;
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 0.8rem;
  }
  .article-tile {
    display: flex; flex-direction: column; gap: 0.55rem;
    padding: 1.1rem 1.2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text);
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .article-tile:hover {
    border-color: var(--border-strong);
    background: var(--surface-2);
    text-decoration: none;
  }
  .tile-meta {
    display: flex; gap: 0.6rem; align-items: center;
    font-size: 0.75rem;
  }
  .tile-cat {
    color: var(--accent);
    font-weight: 600;
    background: rgba(214, 37, 56, 0.08);
    padding: 0.1rem 0.5rem;
    border-radius: 100px;
  }
  .tile-date { color: var(--text-dim); font-size: 0.72rem; }
  .tile-title {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.45;
    color: var(--text);
  }
  .tile-summary {
    font-size: 0.83rem;
    color: var(--text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
