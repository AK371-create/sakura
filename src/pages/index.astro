---
import Layout from "../layouts/Layout.astro";
import PlayerCard from "../components/PlayerCard.astro";
import ohtani from "../content/players/ohtani.json";
import imanaga from "../content/players/imanaga.json";
import murakami from "../content/players/murakami.json";

const players = [ohtani, imanaga, murakami];
---
<Layout title="ホーム" description="日本人メジャーリーガーのシーズン成績とStatcast指標を掲載" lang="ja" currentPath="/">
  <h1>日本人メジャーリーガー 2026</h1>
  <p class="lede">シーズン成績と Statcast 指標を選手ごとにまとめました。</p>
  <div class="player-list">
    {players.map((p) => (
      <PlayerCard player={p} lang="ja" href={`/players/${p.key}/`} />
    ))}
  </div>
</Layout>

<style>
  h1 { font-size: 1.8rem; margin-bottom: 0.4rem; }
  .lede { color: var(--muted); margin-bottom: 1.5rem; }
  .player-list { display: grid; gap: 0.6rem; }
</style>
