---
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const modules = import.meta.glob("../../content/articles/*.json", { eager: true });
  const articles = Object.values(modules).map((m: any) => m.default)
    .sort((a: any, b: any) => (a.date < b.date ? 1 : -1));
  return articles.map((article: any, i: number) => ({
    params: { slug: article.slug },
    props: {
      article,
      prev: articles[i - 1] ?? null,
      next: articles[i + 1] ?? null,
      related: articles
        .filter((x: any) => x.slug !== article.slug && x.category === article.category)
        .slice(0, 3),
    },
  }));
}

const { article, prev, next, related } = Astro.props;

const categoryLabels: Record<string, string> = {
  player: "選手", statcast: "Statcast", history: "歴史", rivalry: "対戦",
  rules: "ルール", team: "チーム", prospects: "若手", culture: "文化", market: "市場",
};
const catLabel = categoryLabels[article.category] ?? article.category;

const wordCount = article.body_jp.join("").length;
const readMin = Math.max(1, Math.round(wordCount / 500));
---
<Layout
  title={article.title_jp}
  description={article.summary_jp}
  lang="ja"
  currentPath={`/articles/${article.slug}/`}
>
  <nav class="breadcrumb">
    <a href="/">← ホーム</a>
    <span class="sep">/</span>
    <a href="/articles/">記事</a>
    <span class="sep">/</span>
    <span class="current">{catLabel}</span>
  </nav>

  <article class="article">
    <header class="article-header">
      <div class="meta">
        <span class="meta-cat">{catLabel}</span>
        <span class="sep">·</span>
        <span class="meta-date mono">{article.date}</span>
        <span class="sep">·</span>
        <span class="meta-read">{readMin}分で読了</span>
      </div>
      <h1 class="article-title">{article.title_jp}</h1>
      <p class="article-summary">{article.summary_jp}</p>
    </header>

    <div class="article-body">
      {article.body_jp.map((p: string) => <p>{p}</p>)}
    </div>

    <footer class="article-footer">
      <div class="tags">
        {article.tags.map((t: string) => <span class="tag mono">#{t}</span>)}
      </div>
    </footer>
  </article>

  {(prev || next) && (
    <nav class="pager" aria-label="記事ナビゲーション">
      {prev ? (
        <a class="pager-link prev" href={`/articles/${prev.slug}/`}>
          <span class="pager-label">← 新しい記事</span>
          <span class="pager-title">{prev.title_jp}</span>
        </a>
      ) : <div></div>}
      {next ? (
        <a class="pager-link next" href={`/articles/${next.slug}/`}>
          <span class="pager-label">古い記事 →</span>
          <span class="pager-title">{next.title_jp}</span>
        </a>
      ) : <div></div>}
    </nav>
  )}

  {related.length > 0 && (
    <section class="related">
      <div class="related-head">関連記事 · {catLabel}</div>
      <div class="related-grid">
        {related.map((r: any) => (
          <a class="related-card" href={`/articles/${r.slug}/`}>
            <span class="rc-date mono">{r.date}</span>
            <span class="rc-title">{r.title_jp}</span>
          </a>
        ))}
      </div>
    </section>
  )}
</Layout>

<style>
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--text-dim); margin-bottom: 1.5rem;
    display: flex; gap: 0.5rem; align-items: center;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--text-muted); }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb .sep { color: var(--text-dim); }
  .breadcrumb .current { color: var(--accent); font-weight: 600; }

  .article {
    max-width: var(--reading-width);
    margin: 0 auto;
  }

  .article-header {
    padding: 2rem 0 2.2rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.2rem;
  }
  .meta {
    display: flex; align-items: center; gap: 0.55rem; flex-wrap: wrap;
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-bottom: 1.3rem;
  }
  .meta-cat {
    color: var(--accent); font-weight: 600;
    background: rgba(214, 37, 56, 0.08);
    padding: 0.18rem 0.6rem;
    border-radius: 100px;
    font-size: 0.78rem;
  }
  .meta-date { color: var(--text-muted); font-weight: 500; }
  .meta-read { color: var(--text-dim); }
  .meta .sep { color: var(--text-dim); }

  .article-title {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.025em;
    margin: 0 0 1.2rem;
    color: var(--text);
  }
  .article-summary {
    font-size: 1.08rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin: 0;
    padding: 1.1rem 1.2rem;
    background: var(--surface);
    border-left: 2px solid var(--accent);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .article-body {
    font-size: 1.02rem;
    line-height: 1.9;
    color: var(--text);
  }
  .article-body p { margin: 0 0 1.3rem; }

  .article-footer {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .tag {
    font-size: 0.7rem; font-weight: 500;
    color: var(--text-muted);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-sm);
    letter-spacing: 0.05em;
  }

  .pager {
    max-width: var(--reading-width);
    margin: 2rem auto 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
  }
  .pager-link {
    display: flex; flex-direction: column; gap: 0.4rem;
    padding: 1.1rem 1.2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text);
    transition: all 0.18s ease;
  }
  .pager-link:hover {
    border-color: var(--accent);
    background: var(--surface-2);
    text-decoration: none;
  }
  .pager-link.next { text-align: right; }
  .pager-label {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-weight: 500;
  }
  .pager-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related {
    max-width: var(--reading-width);
    margin: 3rem auto 0;
  }
  .related-head {
    font-size: 0.95rem;
    color: var(--text);
    margin-bottom: 1rem;
    font-weight: 700;
    padding-bottom: 0.7rem;
    border-bottom: 1px solid var(--border);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.7rem;
  }
  .related-card {
    display: flex; flex-direction: column; gap: 0.35rem;
    padding: 0.95rem 1.1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text);
    transition: all 0.18s ease;
  }
  .related-card:hover {
    border-color: var(--accent);
    background: var(--surface-2);
    text-decoration: none;
  }
  .rc-date {
    font-size: 0.75rem;
    color: var(--text-dim);
  }
  .rc-title {
    font-size: 0.88rem; font-weight: 600;
    line-height: 1.4;
    color: var(--text);
  }

  @media (max-width: 640px) {
    .pager { grid-template-columns: 1fr; }
    .pager-link.next { text-align: left; }
  }
</style>
