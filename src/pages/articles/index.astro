---
import Layout from "../../layouts/Layout.astro";

const modules = import.meta.glob("../../content/articles/*.json", { eager: true });
const articles = Object.values(modules)
  .map((m: any) => m.default)
  .sort((a: any, b: any) => (a.date < b.date ? 1 : -1));

const categoryLabels: Record<string, string> = {
  player: "選手", statcast: "Statcast", history: "歴史", rivalry: "対戦",
  rules: "ルール", team: "チーム", prospects: "若手", culture: "文化", market: "市場",
};
const categories = ["all", ...Array.from(new Set(articles.map((a: any) => a.category)))];
---
<Layout title="Analysis" description="日本人メジャーリーガーに関する分析記事・ニュース一覧" lang="ja" currentPath="/articles/">
  <nav class="breadcrumb"><a href="/">← ホーム</a> <span class="sep">/</span> <span class="current">記事</span></nav>

  <header class="page-hero">
    <div class="hero-eyebrow">記事 / 全{articles.length}本</div>
    <h1>記事</h1>
    <p>日本人メジャーリーガーの分析・歴史・展望。</p>
  </header>

  <div class="toolbar">
    <div class="filter-bar" role="tablist" aria-label="カテゴリフィルター">
      {categories.map((c) => (
        <button class="filter-chip" data-cat={c} role="tab" aria-selected={c === "all"}>
          {c === "all" ? "すべて" : (categoryLabels[c] ?? c)}
        </button>
      ))}
    </div>
  </div>

  <div class="article-table">
    <div class="table-head">
      <span class="col-date">日付</span>
      <span class="col-cat">カテゴリ</span>
      <span class="col-title">タイトル</span>
    </div>
    <div class="table-body">
      {articles.map((a: any) => (
        <a class="row" href={`/articles/${a.slug}/`} data-cat={a.category}>
          <span class="col-date mono">{a.date}</span>
          <span class="col-cat">{categoryLabels[a.category] ?? a.category}</span>
          <span class="col-title">
            <span class="title">{a.title_jp}</span>
            <span class="summary">{a.summary_jp}</span>
            <span class="tags">
              {a.tags.map((t: string) => <span class="tag mono">#{t}</span>)}
            </span>
          </span>
        </a>
      ))}
    </div>
  </div>
</Layout>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>(".filter-chip");
  const rows = document.querySelectorAll<HTMLAnchorElement>(".article-table .row");
  chips.forEach((chip) => {
    chip.addEventListener("click", () => {
      const cat = chip.dataset.cat;
      chips.forEach((c) => c.setAttribute("aria-selected", c === chip ? "true" : "false"));
      rows.forEach((row) => {
        const show = cat === "all" || row.dataset.cat === cat;
        (row as HTMLElement).style.display = show ? "" : "none";
      });
    });
  });
</script>

<style>
  .breadcrumb {
    font-size: 0.82rem;
    color: var(--text-dim); margin-bottom: 1.5rem;
    display: flex; gap: 0.5rem; align-items: center;
  }
  .breadcrumb a { color: var(--text-muted); }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb .sep { color: var(--text-dim); }
  .breadcrumb .current { color: var(--text); font-weight: 600; }

  .page-hero { padding: 2rem 0 2rem; }
  .hero-eyebrow {
    font-size: 0.85rem; font-weight: 600;
    color: var(--accent);
    margin-bottom: 0.8rem;
  }
  .page-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    margin: 0 0 0.6rem;
    line-height: 1;
  }
  .page-hero p {
    color: var(--text-muted);
    font-size: 1rem; margin: 0;
    max-width: 560px;
  }

  .toolbar {
    margin: 2rem 0 1.2rem;
    padding: 0.8rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .filter-bar { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .filter-chip {
    appearance: none; cursor: pointer;
    background: transparent;
    border: 1px solid var(--border);
    padding: 0.4rem 0.95rem;
    border-radius: 100px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-muted);
    font-family: inherit;
    transition: all 0.15s ease;
  }
  .filter-chip:hover { border-color: var(--border-strong); color: var(--text); background: var(--surface); }
  .filter-chip[aria-selected="true"] {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }

  /* Table layout */
  .article-table {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .table-head {
    display: grid;
    grid-template-columns: 100px 110px 1fr;
    padding: 0.85rem 1.3rem;
    background: var(--bg-elev);
    border-bottom: 1px solid var(--border);
    font-size: 0.78rem; font-weight: 600;
    color: var(--text-muted);
  }
  .table-body { display: flex; flex-direction: column; }
  .row {
    display: grid;
    grid-template-columns: 100px 110px 1fr;
    padding: 1rem 1.3rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    transition: background 0.15s ease;
    gap: 0.6rem;
    align-items: flex-start;
  }
  .row:last-child { border-bottom: none; }
  .row:hover {
    background: var(--surface-2);
    text-decoration: none;
  }
  .row:hover .title { color: var(--accent); }

  .col-date {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-feature-settings: "tnum" 1;
    padding-top: 0.15rem;
  }
  .col-cat {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    padding-top: 0.2rem;
  }
  .col-title { display: flex; flex-direction: column; gap: 0.3rem; min-width: 0; }
  .title {
    font-size: 1rem; font-weight: 600;
    line-height: 1.4;
    color: var(--text);
    transition: color 0.15s ease;
  }
  .summary {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.55;
  }
  .tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: 0.15rem; }
  .tag {
    font-size: 0.7rem; font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-elev);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
  }

  @media (max-width: 640px) {
    .table-head, .row {
      grid-template-columns: 1fr;
      gap: 0.4rem;
      padding: 0.9rem 1rem;
    }
    .table-head .col-cat, .table-head .col-title { display: none; }
    .col-date { padding: 0; font-size: 0.7rem; }
    .col-cat { padding: 0; }
  }
</style>
