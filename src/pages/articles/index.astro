---
import Layout from "../../layouts/Layout.astro";

const modules = import.meta.glob("../../content/articles/*.json", { eager: true });
const articles = Object.values(modules)
  .map((m: any) => m.default)
  .sort((a: any, b: any) => (a.date < b.date ? 1 : -1));

const categoryLabels: Record<string, string> = {
  player: "選手", statcast: "Statcast", history: "歴史", rivalry: "対戦",
  rules: "ルール", team: "チーム", prospects: "若手", culture: "文化", market: "市場",
};
const categories = ["all", ...Array.from(new Set(articles.map((a: any) => a.category)))];
---
<Layout title="記事一覧" description="日本人メジャーリーガーに関する分析記事・ニュース一覧" lang="ja" currentPath="/articles/">
  <header class="page-header">
    <h1>記事</h1>
    <p class="page-lede">日本人メジャーリーガーの分析・歴史・展望をまとめた記事一覧。</p>
  </header>

  <div class="filter-bar" role="tablist" aria-label="カテゴリフィルター">
    {categories.map((c) => (
      <button class="filter-chip" data-cat={c} role="tab" aria-selected={c === "all"}>
        {c === "all" ? "すべて" : (categoryLabels[c] ?? c)}
      </button>
    ))}
  </div>

  <div class="article-list">
    {articles.map((a: any, i: number) => (
      <a class="article-card" href={`/articles/${a.slug}/`} data-cat={a.category} style={`--idx: ${i}`}>
        <div class="card-side">
          <span class="card-date">{a.date}</span>
          <span class="card-cat">{categoryLabels[a.category] ?? a.category}</span>
        </div>
        <div class="card-main">
          <h2 class="card-title">{a.title_jp}</h2>
          <p class="card-summary">{a.summary_jp}</p>
          <div class="card-tags">
            {a.tags.map((t: string) => <span class="tag">#{t}</span>)}
          </div>
        </div>
      </a>
    ))}
  </div>
</Layout>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>(".filter-chip");
  const cards = document.querySelectorAll<HTMLAnchorElement>(".article-card");
  chips.forEach((chip) => {
    chip.addEventListener("click", () => {
      const cat = chip.dataset.cat;
      chips.forEach((c) => c.setAttribute("aria-selected", c === chip ? "true" : "false"));
      cards.forEach((card) => {
        const show = cat === "all" || card.dataset.cat === cat;
        (card as HTMLElement).style.display = show ? "" : "none";
      });
    });
  });
</script>

<style>
  .page-header { margin-bottom: 1.8rem; }
  .page-header h1 {
    font-family: var(--font-display);
    font-size: 2.2rem; font-weight: 700; margin: 0 0 0.4rem;
    letter-spacing: -0.02em;
  }
  .page-lede { color: var(--text-muted); margin: 0; font-size: 1rem; }

  .filter-bar {
    display: flex; gap: 0.5rem; flex-wrap: wrap;
    margin-bottom: 1.8rem;
    padding-bottom: 1.2rem;
    border-bottom: 1px solid var(--border);
  }
  .filter-chip {
    appearance: none; cursor: pointer;
    background: transparent; border: 1px solid var(--border);
    padding: 0.4rem 0.95rem;
    border-radius: 100px;
    font-size: 0.8rem; font-weight: 500;
    color: var(--text-muted);
    font-family: inherit;
    transition: all 0.15s ease;
  }
  .filter-chip:hover { background: var(--rose-100); color: var(--rose-700); }
  .filter-chip[aria-selected="true"] {
    background: var(--accent); color: white; border-color: var(--accent);
  }

  .article-list {
    display: flex; flex-direction: column;
    gap: 0.7rem;
  }
  .article-card {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 1.4rem;
    padding: 1.3rem 1.4rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    color: var(--text);
    box-shadow: var(--shadow-sm);
    transition: all 0.18s ease;
    position: relative;
    overflow: hidden;
  }
  .article-card::after {
    content: "→";
    position: absolute;
    right: 1.2rem; bottom: 1.2rem;
    color: var(--text-muted);
    font-size: 1rem;
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .article-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--rose-200);
    text-decoration: none;
  }
  .article-card:hover::after { transform: translateX(4px); color: var(--accent); }

  .card-side {
    display: flex; flex-direction: column; gap: 0.4rem;
    padding-top: 0.1rem;
  }
  .card-date {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }
  .card-cat {
    align-self: flex-start;
    background: var(--rose-100); color: var(--rose-700);
    padding: 0.18rem 0.6rem;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .card-main { display: flex; flex-direction: column; gap: 0.4rem; min-width: 0; }
  .card-title {
    font-family: var(--font-display);
    font-size: 1.18rem;
    font-weight: 700;
    line-height: 1.4;
    margin: 0;
    color: var(--text);
  }
  .card-summary {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0;
  }
  .card-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: 0.2rem; }
  .tag {
    font-size: 0.7rem;
    color: var(--text-muted);
    background: var(--rose-50);
    padding: 0.12rem 0.5rem;
    border-radius: 4px;
  }

  @media (max-width: 640px) {
    .article-card {
      grid-template-columns: 1fr;
      gap: 0.7rem;
      padding: 1.1rem 1.2rem;
    }
    .card-side { flex-direction: row; align-items: center; }
    .article-card::after { display: none; }
    .card-title { font-size: 1.05rem; }
  }
</style>
