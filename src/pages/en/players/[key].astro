---
import Layout from "../../../layouts/Layout.astro";
import { BATTING_SPECS, percentile, percentileColor } from "../../../lib/percentiles";

export async function getStaticPaths() {
  const modules = import.meta.glob("../../../content/players/*.json", { eager: true });
  return Object.values(modules).map((m: any) => ({
    params: { key: m.default.key },
    props: { player: m.default },
  }));
}

const { player } = Astro.props;
const hitting = player.basic?.hitting;
const pitching = player.basic?.pitching;
const savantHit = player.savant?.hitting;
const arsenal = player.savant?.pitch_arsenal;

const typeCode = { two_way: "TWO-WAY", batter: "BATTER", pitcher: "PITCHER" }[player.type] ?? player.type;
const isFormer = player.level === "FORMER";
let leagueLabel: string;
if (player.level === "AAA") leagueLabel = "AAA";
else if (isFormer) leagueLabel = "FORMER";
else leagueLabel = player.league;

const percentileMetrics = savantHit ? [
  { key: "exit_velocity_avg", label: "Exit Velocity", value: savantHit.exit_velocity_avg, fmt: (v: number) => `${v} mph` },
  { key: "barrel_batted_rate", label: "Barrel %", value: savantHit.barrel_batted_rate, fmt: (v: number) => `${v}%` },
  { key: "hard_hit_percent", label: "Hard-Hit %", value: savantHit.hard_hit_percent, fmt: (v: number) => `${v}%` },
  { key: "xba", label: "xBA", value: savantHit.xba, fmt: (v: string) => v },
  { key: "xslg", label: "xSLG", value: savantHit.xslg, fmt: (v: string) => v },
  { key: "xwoba", label: "xwOBA", value: savantHit.xwoba, fmt: (v: string) => v },
  { key: "k_percent", label: "K %", value: savantHit.k_percent, fmt: (v: number) => `${v}%` },
  { key: "bb_percent", label: "BB %", value: savantHit.bb_percent, fmt: (v: number) => `${v}%` },
].map((m) => {
  const spec = BATTING_SPECS[m.key];
  const pct = spec ? percentile(m.value, spec) : 50;
  return { ...m, pct };
}) : [];

const pitchColors: Record<string, string> = {
  FF: "var(--pitch-ff)", FT: "var(--pitch-ft)", FS: "var(--pitch-fs)", FC: "var(--pitch-fc)",
  SI: "var(--pitch-si)", SL: "var(--pitch-sl)", CU: "var(--pitch-cu)", CH: "var(--pitch-ch)", KC: "var(--pitch-kc)",
};

const yearly = player.yearly ?? [];
const hittingYearly = yearly.filter((y: any) => y.type === "hit");
const pitchingYearly = yearly.filter((y: any) => y.type === "pit");

function rankYears(rows: any[], field: string, higherBetter: boolean) {
  if (!rows.length) return [];
  const values = rows.map((r, i) => ({ i, v: parseFloat(r[field]) }));
  values.sort((a, b) => {
    const av = isNaN(a.v) ? -Infinity : a.v;
    const bv = isNaN(b.v) ? -Infinity : b.v;
    return higherBetter ? bv - av : av - bv;
  });
  const ranks: number[] = new Array(rows.length).fill(0);
  values.forEach((item, idx) => { ranks[item.i] = idx + 1; });
  return ranks;
}
function statClass(row: any, field: string, careerRank?: number): string {
  if (row.led && row.led.includes(field)) return "rank-1";
  if (row.top10 && row.top10.includes(field)) return "rank-top";
  if (careerRank === 1) return "career-high";
  return "";
}
const hitCareerRanks = {
  avg: rankYears(yearly.filter((y: any) => y.type === "hit"), "avg", true),
  h: rankYears(yearly.filter((y: any) => y.type === "hit"), "h", true),
  hr: rankYears(yearly.filter((y: any) => y.type === "hit"), "hr", true),
  rbi: rankYears(yearly.filter((y: any) => y.type === "hit"), "rbi", true),
  sb: rankYears(yearly.filter((y: any) => y.type === "hit"), "sb", true),
  obp: rankYears(yearly.filter((y: any) => y.type === "hit"), "obp", true),
  slg: rankYears(yearly.filter((y: any) => y.type === "hit"), "slg", true),
  ops: rankYears(yearly.filter((y: any) => y.type === "hit"), "ops", true),
};
const pitCareerRanks = {
  w: rankYears(yearly.filter((y: any) => y.type === "pit"), "w", true),
  l: rankYears(yearly.filter((y: any) => y.type === "pit"), "l", false),
  era: rankYears(yearly.filter((y: any) => y.type === "pit"), "era", false),
  so: rankYears(yearly.filter((y: any) => y.type === "pit"), "so", true),
  ip: rankYears(yearly.filter((y: any) => y.type === "pit"), "ip", true),
  whip: rankYears(yearly.filter((y: any) => y.type === "pit"), "whip", false),
  sv: rankYears(yearly.filter((y: any) => y.type === "pit"), "sv", true),
  hld: rankYears(yearly.filter((y: any) => y.type === "pit"), "hld", true),
};

const STAT_LABEL_EN: Record<string, string> = {
  avg: "AVG", h: "H", hr: "HR", rbi: "RBI", sb: "SB", ops: "OPS",
  era: "ERA", w: "W", l: "L", so: "SO", ip: "IP", whip: "WHIP",
};
const ledSeasons = yearly
  .filter((y: any) => y.led && y.led.length > 0)
  .map((y: any) => ({
    year: y.year, team: y.team, type: y.type,
    items: y.led.map((field: string) => ({ field, value: y[field], label: STAT_LABEL_EN[field] ?? field })),
  }));

// Awards (English labels)
const AWARD_EN: Record<string, string> = {
  "ws-mvp": "World Series MVP",
  "mvp": "League MVP",
  "cy": "Cy Young Award",
  "roy": "Rookie of the Year",
  "alcs-mvp": "ALCS MVP",
  "nlcs-mvp": "NLCS MVP",
  "silver": "Silver Slugger",
  "gold": "Gold Glove",
  "aaron": "Hank Aaron Award",
  "comeback": "Comeback Player",
  "historic": "Commissioner's Historic",
  "as": "All-Star",
};
const allAwards = (player.awards ?? []) as Array<{year: number; label: string; cat: string}>;
type AwardGroup = { label: string; cat: string; count: number; years: number[] };
const awardsByCat: Map<string, AwardGroup> = new Map();
for (const a of allAwards) {
  const g = awardsByCat.get(a.cat);
  if (g) { g.count++; g.years.push(a.year); }
  else { awardsByCat.set(a.cat, { label: AWARD_EN[a.cat] ?? a.label, cat: a.cat, count: 1, years: [a.year] }); }
}
const CAT_ORDER = ["ws-mvp", "mvp", "cy", "roy", "alcs-mvp", "nlcs-mvp", "silver", "gold", "aaron", "comeback", "historic", "as"];
const groupedAwards = Array.from(awardsByCat.values())
  .sort((a, b) => CAT_ORDER.indexOf(a.cat) - CAT_ORDER.indexOf(b.cat));

const playerJsonLd: object[] = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": player.name_en,
    "alternateName": player.name_jp,
    "url": `https://sakuraballpark.com/en/players/${player.key}/`,
    "jobTitle": player.position_en,
    "affiliation": isFormer ? undefined : {
      "@type": "SportsTeam",
      "name": player.team_en,
      "alternateName": player.team_jp,
    },
    "nationality": "Japan",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sakuraballpark.com/en/" },
      { "@type": "ListItem", "position": 2, "name": "Players", "item": "https://sakuraballpark.com/en/#players" },
      { "@type": "ListItem", "position": 3, "name": player.name_en, "item": `https://sakuraballpark.com/en/players/${player.key}/` },
    ],
  },
];
---
<Layout
  title={player.name_en}
  description={`${player.name_en} (${player.team_en}) — ${isFormer ? "MLB career stats" : "2026 season stats"}, year-by-year data, awards`}
  lang="en"
  currentPath={`/en/players/${player.key}/`}
  ogType="profile"
  jsonLd={playerJsonLd}
  modifiedDate={player.updated_at}
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/en/" class="bc-item"><span class="bc-icon" aria-hidden="true">⌂</span>Home</a>
    <span class="bc-chevron" aria-hidden="true">›</span>
    <a href="/en/#players" class="bc-item">Players</a>
    <span class="bc-chevron" aria-hidden="true">›</span>
    <span class="bc-item bc-current">{player.name_en}</span>
  </nav>

  <header class="player-hero">
    <div class="hero-tags">
      <span class={`tag type type-${player.type}`}>{typeCode}</span>
      <span class:list={["tag league", `league-${player.league.toLowerCase()}`, { former: isFormer }]}>{leagueLabel}</span>
    </div>
    <h1 class="player-name">{player.name_en}</h1>
    <div class="player-meta">
      <span class="team">{isFormer ? `${player.team_en} (last MLB team)` : player.team_en}</span>
      <span class="sep">·</span>
      <span class="pos">{player.position_en}</span>
    </div>
    {isFormer && (
      <div class="former-info">
        <div class="former-row"><span class="former-lbl">MLB years</span><span class="former-val mono">{player.mlb_years}</span></div>
        <div class="former-row"><span class="former-lbl">Status</span><span class="former-val">{player.current_status_en}</span></div>
      </div>
    )}
  </header>

  {isFormer && (
    <div class="career-banner">
      <span class="banner-label">MLB Career Totals</span>
      <span class="banner-years mono">{player.mlb_years}</span>
    </div>
  )}

  {groupedAwards.length > 0 && (
    <section class="awards-panel">
      <div class="awards-head">
        <span class="awards-icon" aria-hidden="true">🏅</span>
        <h2>Awards</h2>
        <span class="awards-count">{allAwards.length} total</span>
      </div>
      <div class="awards-grid">
        {groupedAwards.map((g) => (
          <div class={"award-card cat-" + g.cat}>
            <div class="award-label">{g.label}</div>
            <div class="award-meta">
              {g.count > 1 && <span class="award-count">{g.count}x</span>}
              <span class="award-years mono">
                {g.years.length <= 3
                  ? g.years.join(", ")
                  : Math.min(...g.years) + "–" + Math.max(...g.years)}
              </span>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {ledSeasons.length > 0 && (
    <section class="led-panel">
      <div class="led-head">
        <span class="led-icon" aria-hidden="true">🏆</span>
        <h2>MLB-Leading Stats</h2>
        <span class="led-count">{ledSeasons.reduce((s: number, x: any) => s + x.items.length, 0)} titles</span>
      </div>
      <div class="led-list">
        {ledSeasons.map((s: any) => (
          <div class="led-row">
            <div class="led-year mono">{s.year}</div>
            <div class="led-team mono">{s.team}</div>
            <div class="led-items">
              {s.items.map((it: any) => (
                <span class="led-item">
                  <span class="led-label">{it.label}</span>
                  <span class="led-value mono">{it.value}</span>
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {hitting && (
    <section class="summary-row">
      <div class="summary-card primary"><div class="sc-label mono">AVG</div><div class="sc-value mono">{hitting.avg}</div></div>
      {hitting.h !== undefined && (
        <div class="summary-card"><div class="sc-label mono">H</div><div class="sc-value mono">{hitting.h}</div></div>
      )}
      <div class="summary-card"><div class="sc-label mono">HR</div><div class="sc-value mono">{hitting.hr}</div></div>
      <div class="summary-card"><div class="sc-label mono">RBI</div><div class="sc-value mono">{hitting.rbi}</div></div>
      <div class="summary-card"><div class="sc-label mono">OBP</div><div class="sc-value mono">{hitting.obp}</div></div>
      {hitting.slg !== undefined && (
        <div class="summary-card"><div class="sc-label mono">SLG</div><div class="sc-value mono">{hitting.slg}</div></div>
      )}
      <div class="summary-card primary"><div class="sc-label mono">OPS</div><div class="sc-value mono">{hitting.ops}</div></div>
      <div class="summary-card"><div class="sc-label mono">SB</div><div class="sc-value mono">{hitting.sb}</div></div>
    </section>
  )}

  {pitching && (
    <section class="summary-row">
      <div class="summary-card primary"><div class="sc-label mono">ERA</div><div class="sc-value mono">{pitching.era}</div></div>
      <div class="summary-card"><div class="sc-label mono">W-L</div><div class="sc-value mono">{pitching.w}-{pitching.l}</div></div>
      {pitching.sv !== undefined && (
        <div class="summary-card"><div class="sc-label mono">SV</div><div class="sc-value mono">{pitching.sv}</div></div>
      )}
      {pitching.hld !== undefined && (
        <div class="summary-card"><div class="sc-label mono">HLD</div><div class="sc-value mono">{pitching.hld}</div></div>
      )}
      <div class="summary-card primary"><div class="sc-label mono">SO</div><div class="sc-value mono">{pitching.so}</div></div>
      <div class="summary-card"><div class="sc-label mono">WHIP</div><div class="sc-value mono">{pitching.whip}</div></div>
      <div class="summary-card"><div class="sc-label mono">IP</div><div class="sc-value mono">{pitching.ip}</div></div>
    </section>
  )}

  {hittingYearly.length > 0 && (
    <section class="panel">
      <div class="panel-head">
        <h2>Year-by-Year{pitchingYearly.length > 0 ? " (Hitting)" : ""}</h2>
        <span class="panel-sub mono">{player.mlb_years ?? ""}</span>
      </div>
      <div class="yearly-wrap">
        <table class="yearly-table">
          <thead>
            <tr>
              <th class="num">Year</th>
              <th>Team</th>
              <th class="num">AVG</th>
              <th class="num">H</th>
              <th class="num">HR</th>
              <th class="num">RBI</th>
              <th class="num">SB</th>
              {hittingYearly.some((y: any) => y.obp) && <th class="num">OBP</th>}
              {hittingYearly.some((y: any) => y.slg) && <th class="num">SLG</th>}
              <th class="num">OPS</th>
            </tr>
          </thead>
          <tbody>
            {hittingYearly.map((y: any, i: number) => (
              <tr>
                <td class="num mono">{y.year}</td>
                <td class="mono">{y.team}</td>
                <td class:list={["num", "mono", statClass(y, "avg", hitCareerRanks.avg[i])]}>{y.avg}</td>
                <td class:list={["num", "mono", statClass(y, "h", hitCareerRanks.h[i])]}>{y.h}</td>
                <td class:list={["num", "mono", statClass(y, "hr", hitCareerRanks.hr[i])]}>{y.hr}</td>
                <td class:list={["num", "mono", statClass(y, "rbi", hitCareerRanks.rbi[i])]}>{y.rbi}</td>
                <td class:list={["num", "mono", statClass(y, "sb", hitCareerRanks.sb[i])]}>{y.sb}</td>
                {hittingYearly.some((r: any) => r.obp) && <td class:list={["num", "mono", statClass(y, "obp", hitCareerRanks.obp[i])]}>{y.obp ?? "—"}</td>}
                {hittingYearly.some((r: any) => r.slg) && <td class:list={["num", "mono", statClass(y, "slg", hitCareerRanks.slg[i])]}>{y.slg ?? "—"}</td>}
                <td class:list={["num", "mono", statClass(y, "ops", hitCareerRanks.ops[i])]}>{y.ops}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="rank-legend mono">
        <span class="legend-item"><span class="legend-swatch career-high"></span>CAREER HIGH</span>
        <span class="legend-item"><span class="legend-swatch rank-top"></span>MLB TOP 10</span>
        <span class="legend-item"><span class="legend-swatch rank-1"></span><strong>MLB #1</strong></span>
      </div>
    </section>
  )}

  {pitchingYearly.length > 0 && (
    <section class="panel">
      <div class="panel-head">
        <h2>Year-by-Year{hittingYearly.length > 0 ? " (Pitching)" : ""}</h2>
        <span class="panel-sub mono">{player.mlb_years ?? ""}</span>
      </div>
      <div class="yearly-wrap">
        <table class="yearly-table">
          <thead>
            <tr>
              <th class="num">Year</th>
              <th>Team</th>
              <th class="num">W</th>
              <th class="num">L</th>
              <th class="num">ERA</th>
              <th class="num">SO</th>
              <th class="num">IP</th>
              <th class="num">WHIP</th>
              {pitchingYearly.some((y: any) => y.sv !== undefined) && <th class="num">SV</th>}
              {pitchingYearly.some((y: any) => y.hld !== undefined) && <th class="num">HLD</th>}
            </tr>
          </thead>
          <tbody>
            {pitchingYearly.map((y: any, i: number) => (
              <tr>
                <td class="num mono">{y.year}</td>
                <td class="mono">{y.team}</td>
                <td class:list={["num", "mono", statClass(y, "w", pitCareerRanks.w[i])]}>{y.w}</td>
                <td class:list={["num", "mono", statClass(y, "l", pitCareerRanks.l[i])]}>{y.l}</td>
                <td class:list={["num", "mono", statClass(y, "era", pitCareerRanks.era[i])]}>{y.era}</td>
                <td class:list={["num", "mono", statClass(y, "so", pitCareerRanks.so[i])]}>{y.so}</td>
                <td class:list={["num", "mono", statClass(y, "ip", pitCareerRanks.ip[i])]}>{y.ip}</td>
                <td class:list={["num", "mono", statClass(y, "whip", pitCareerRanks.whip[i])]}>{y.whip}</td>
                {pitchingYearly.some((r: any) => r.sv !== undefined) && <td class:list={["num", "mono", statClass(y, "sv", pitCareerRanks.sv[i])]}>{y.sv ?? "—"}</td>}
                {pitchingYearly.some((r: any) => r.hld !== undefined) && <td class:list={["num", "mono", statClass(y, "hld", pitCareerRanks.hld[i])]}>{y.hld ?? "—"}</td>}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {!hittingYearly.length && (
        <div class="rank-legend mono">
          <span class="legend-item"><span class="legend-swatch rank-1"></span>CAREER #1</span>
          <span class="legend-item"><span class="legend-swatch rank-top"></span>TOP 10</span>
        </div>
      )}
    </section>
  )}

  {false && percentileMetrics.length > 0 && (
    <section class="panel">
      <div class="panel-head">
        <h2>Percentile Rankings</h2>
        <span class="panel-sub mono">BATTING · 2026</span>
      </div>
      <div class="pct-list"></div>
      <div class="pct-legend mono"></div>
    </section>
  )}

  {arsenal && arsenal.length > 0 && (
    <section class="panel">
      <div class="panel-head">
        <h2>Pitch Arsenal</h2>
        <span class="panel-sub mono">{player.savant?.arsenal_season ?? 2026} SEASON · USAGE · AVG VELOCITY (MLB Stats API)</span>
      </div>
      <table class="arsenal-table">
        <thead>
          <tr>
            <th>Pitch</th>
            <th class="num">Usage</th>
            <th class="dist">Distribution</th>
            <th class="num">Avg Velocity (mph)</th>
          </tr>
        </thead>
        <tbody>
          {arsenal.map((a: any) => (
            <tr>
              <td>
                <div class="pitch-cell">
                  <span class="pitch-dot" style={`background: ${pitchColors[a.pitch] ?? "var(--pitch-default)"}`}></span>
                  <div>
                    <div class="pitch-name">{a.en}</div>
                    <div class="pitch-sub mono">{a.pitch}</div>
                  </div>
                </div>
              </td>
              <td class="num mono">{a.usage}%</td>
              <td class="dist">
                <div class="dist-bars">
                  <div class="dist-bar" style={`--w: ${Math.min(a.usage, 100)}%; --c: ${pitchColors[a.pitch] ?? "var(--pitch-default)"}`} title={`Usage ${a.usage}%`}></div>
                </div>
              </td>
              <td class="num mono">{a.speed ? a.speed.toFixed(1) : "—"}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  <div class="footer-meta mono">LAST UPDATED · {player.updated_at}</div>
</Layout>

<style>
  .breadcrumb {
    display: flex; gap: 0.4rem; align-items: center;
    flex-wrap: wrap;
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
    padding: 0.6rem 1rem;
    background: rgba(255, 255, 255, 0.4);
    border: 1px solid var(--border);
    border-radius: 100px;
  }
  .bc-item {
    color: var(--text-muted);
    padding: 0.2rem 0.5rem;
    border-radius: 100px;
    transition: all 0.15s ease;
    display: inline-flex; align-items: center; gap: 0.3rem;
  }
  .bc-item:not(.bc-current):hover {
    background: rgba(214, 37, 56, 0.06);
    color: var(--accent);
    text-decoration: none;
  }
  .bc-icon { font-size: 0.95rem; line-height: 1; color: inherit; }
  .bc-current { color: var(--accent); font-weight: 600; background: rgba(214, 37, 56, 0.08); }
  .bc-chevron { color: var(--text-dim); font-size: 1rem; line-height: 1; }

  .player-hero {
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2rem;
  }
  .hero-tags { display: flex; gap: 0.4rem; margin-bottom: 0.8rem; }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.65rem; font-weight: 600;
    letter-spacing: 0.1em;
    padding: 0.22rem 0.55rem;
    border-radius: var(--radius-sm);
  }
  .tag.type { background: rgba(214, 37, 56, 0.08); color: var(--sv-red); border: 1px solid rgba(214, 37, 56, 0.2); }
  .tag.type.type-two_way { background: linear-gradient(90deg, rgba(214, 37, 56, 0.1), rgba(237, 124, 44, 0.1)); color: var(--sv-orange); border-color: rgba(237, 124, 44, 0.25); }
  .tag.league { background: var(--surface-3); color: var(--text-muted); border: 1px solid var(--border); }
  .tag.league.league-nl { color: var(--sv-blue); border-color: rgba(44, 93, 209, 0.25); background: rgba(44, 93, 209, 0.06); }
  .tag.league.league-al { color: var(--sv-red); border-color: rgba(214, 37, 56, 0.25); background: rgba(214, 37, 56, 0.06); }
