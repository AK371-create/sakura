---
import Layout from "../../../layouts/Layout.astro";
import { BATTING_SPECS, percentile, percentileColor } from "../../../lib/percentiles";

export async function getStaticPaths() {
  const ohtani = (await import("../../../content/players/ohtani.json")).default;
  const imanaga = (await import("../../../content/players/imanaga.json")).default;
  const murakami = (await import("../../../content/players/murakami.json")).default;
  const all = [ohtani, imanaga, murakami];
  return all.map((p) => ({ params: { key: p.key }, props: { player: p } }));
}

const { player } = Astro.props;
const hitting = player.basic?.hitting;
const pitching = player.basic?.pitching;
const savantHit = player.savant?.hitting;
const arsenal = player.savant?.pitch_arsenal;

const typeCode = { two_way: "TWO-WAY", batter: "BATTER", pitcher: "PITCHER" }[player.type] ?? player.type;

const percentileMetrics = savantHit ? [
  { key: "exit_velocity_avg", label: "Exit Velocity", value: savantHit.exit_velocity_avg, fmt: (v: number) => `${v} mph` },
  { key: "barrel_batted_rate", label: "Barrel %", value: savantHit.barrel_batted_rate, fmt: (v: number) => `${v}%` },
  { key: "hard_hit_percent", label: "Hard-Hit %", value: savantHit.hard_hit_percent, fmt: (v: number) => `${v}%` },
  { key: "xba", label: "xBA", value: savantHit.xba, fmt: (v: string) => v },
  { key: "xslg", label: "xSLG", value: savantHit.xslg, fmt: (v: string) => v },
  { key: "xwoba", label: "xwOBA", value: savantHit.xwoba, fmt: (v: string) => v },
  { key: "k_percent", label: "K %", value: savantHit.k_percent, fmt: (v: number) => `${v}%` },
  { key: "bb_percent", label: "BB %", value: savantHit.bb_percent, fmt: (v: number) => `${v}%` },
].map((m) => {
  const spec = BATTING_SPECS[m.key];
  const pct = spec ? percentile(m.value, spec) : 50;
  return { ...m, pct };
}) : [];

const pitchColors: Record<string, string> = {
  FF: "var(--pitch-ff)", FT: "var(--pitch-ft)", FS: "var(--pitch-fs)", FC: "var(--pitch-fc)",
  SI: "var(--pitch-si)", SL: "var(--pitch-sl)", CU: "var(--pitch-cu)", CH: "var(--pitch-ch)", KC: "var(--pitch-kc)",
};
---
<Layout
  title={player.name_en}
  description={`${player.name_en} (${player.team_en}) — 2026 season stats and Statcast metrics`}
  lang="en"
  currentPath={`/en/players/${player.key}/`}
>
  <nav class="breadcrumb mono"><a href="/en/">← HOME</a> <span class="sep">/</span> <span>PLAYERS</span> <span class="sep">/</span> <span class="current">{player.key.toUpperCase()}</span></nav>

  <header class="player-hero">
    <div class="hero-tags">
      <span class={`tag type type-${player.type}`}>{typeCode}</span>
      <span class={`tag league league-${player.league.toLowerCase()}`}>{player.league}</span>
    </div>
    <h1 class="player-name">{player.name_en}</h1>
    <div class="player-meta">
      <span class="team">{player.team_en}</span>
      <span class="sep">·</span>
      <span class="pos">{player.position_en}</span>
    </div>
  </header>

  {hitting && (
    <section class="summary-row">
      <div class="summary-card primary"><div class="sc-label mono">AVG</div><div class="sc-value mono">{hitting.avg}</div></div>
      <div class="summary-card"><div class="sc-label mono">HR</div><div class="sc-value mono">{hitting.hr}</div></div>
      <div class="summary-card"><div class="sc-label mono">RBI</div><div class="sc-value mono">{hitting.rbi}</div></div>
      <div class="summary-card"><div class="sc-label mono">OBP</div><div class="sc-value mono">{hitting.obp}</div></div>
      <div class="summary-card primary"><div class="sc-label mono">OPS</div><div class="sc-value mono">{hitting.ops}</div></div>
      <div class="summary-card"><div class="sc-label mono">SB</div><div class="sc-value mono">{hitting.sb}</div></div>
    </section>
  )}

  {pitching && (
    <section class="summary-row">
      <div class="summary-card primary"><div class="sc-label mono">ERA</div><div class="sc-value mono">{pitching.era}</div></div>
      <div class="summary-card"><div class="sc-label mono">W-L</div><div class="sc-value mono">{pitching.w}-{pitching.l}</div></div>
      <div class="summary-card primary"><div class="sc-label mono">SO</div><div class="sc-value mono">{pitching.so}</div></div>
      <div class="summary-card"><div class="sc-label mono">WHIP</div><div class="sc-value mono">{pitching.whip}</div></div>
      <div class="summary-card"><div class="sc-label mono">IP</div><div class="sc-value mono">{pitching.ip}</div></div>
    </section>
  )}

  {percentileMetrics.length > 0 && (
    <section class="panel">
      <div class="panel-head">
        <h2>Percentile Rankings</h2>
        <span class="panel-sub mono">BATTING · 2026</span>
      </div>
      <div class="pct-list">
        {percentileMetrics.map((m) => (
          <div class="pct-row">
            <div class="pct-label">{m.label}</div>
            <div class="pct-track">
              <div class="pct-grid">
                <span class="pct-tick" style="left: 25%"></span>
                <span class="pct-tick" style="left: 50%"></span>
                <span class="pct-tick" style="left: 75%"></span>
              </div>
              <div class="pct-bar" style={`width: ${m.pct}%; background: ${percentileColor(m.pct)};`}></div>
              <div class="pct-dot" style={`left: calc(${m.pct}% - 8px); background: ${percentileColor(m.pct)};`}>
                <span class="pct-num mono">{m.pct}</span>
              </div>
            </div>
            <div class="pct-value mono">{m.fmt(m.value as any)}</div>
          </div>
        ))}
      </div>
      <div class="pct-legend mono">
        <span>←</span>
        <span class="leg-bar"></span>
        <span>POOR</span>
        <span class="leg-mid">AVG</span>
        <span>ELITE</span>
        <span>→</span>
      </div>
    </section>
  )}

  {arsenal && arsenal.length > 0 && (
    <section class="panel">
      <div class="panel-head">
        <h2>Pitch Arsenal</h2>
        <span class="panel-sub mono">USAGE · WHIFF · HARD-HIT</span>
      </div>
      <table class="arsenal-table">
        <thead>
          <tr>
            <th>Pitch</th>
            <th class="num">Usage</th>
            <th class="num">BAA</th>
            <th class="num">Whiff</th>
            <th class="num">Hard-Hit</th>
            <th class="dist">Distribution</th>
          </tr>
        </thead>
        <tbody>
          {arsenal.map((a: any) => (
            <tr>
              <td>
                <div class="pitch-cell">
                  <span class="pitch-dot" style={`background: ${pitchColors[a.pitch] ?? "var(--pitch-default)"}`}></span>
                  <div>
                    <div class="pitch-name">{a.en}</div>
                    <div class="pitch-sub mono">{a.pitch}</div>
                  </div>
                </div>
              </td>
              <td class="num mono">{a.usage}%</td>
              <td class="num mono">{a.ba}</td>
              <td class="num mono">{a.whiff}%</td>
              <td class="num mono">{a.hard_hit}%</td>
              <td class="dist">
                <div class="dist-bars">
                  <div class="dist-bar" style={`--w: ${a.usage}%; --c: ${pitchColors[a.pitch] ?? "var(--pitch-default)"}`} title={`Usage ${a.usage}%`}></div>
                  <div class="dist-bar whiff-bar" style={`--w: ${a.whiff}%;`} title={`Whiff ${a.whiff}%`}></div>
                  <div class="dist-bar hh-bar" style={`--w: ${a.hard_hit}%;`} title={`Hard-Hit ${a.hard_hit}%`}></div>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      <div class="arsenal-legend mono">
        <span><span class="leg-dot" style="background: var(--pitch-default)"></span>USAGE</span>
        <span><span class="leg-dot" style="background: var(--sv-cyan)"></span>WHIFF</span>
        <span><span class="leg-dot" style="background: var(--sv-orange)"></span>HARD-HIT</span>
      </div>
    </section>
  )}

  <div class="footer-meta mono">LAST UPDATED · {player.updated_at}</div>
</Layout>

<style>
  .breadcrumb {
    font-size: 0.7rem; letter-spacing: 0.08em;
    color: var(--text-dim); margin-bottom: 1.5rem;
    display: flex; gap: 0.5rem; align-items: center;
  }
  .breadcrumb a { color: var(--text-muted); }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb .sep { color: var(--text-dim); }
  .breadcrumb .current { color: var(--text); font-weight: 600; }

  .player-hero {
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2rem;
  }
  .hero-tags { display: flex; gap: 0.4rem; margin-bottom: 0.8rem; }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.65rem; font-weight: 600;
    letter-spacing: 0.1em;
    padding: 0.22rem 0.55rem;
    border-radius: var(--radius-sm);
  }
  .tag.type { background: rgba(214, 37, 56, 0.08); color: var(--sv-red); border: 1px solid rgba(214, 37, 56, 0.2); }
  .tag.type.type-two_way { background: linear-gradient(90deg, rgba(214, 37, 56, 0.1), rgba(237, 124, 44, 0.1)); color: var(--sv-orange); border-color: rgba(237, 124, 44, 0.25); }
  .tag.league { background: var(--surface-3); color: var(--text-muted); border: 1px solid var(--border); }
  .tag.league.league-nl { color: var(--sv-blue); border-color: rgba(44, 93, 209, 0.25); background: rgba(44, 93, 209, 0.06); }
  .tag.league.league-al { color: var(--sv-red); border-color: rgba(214, 37, 56, 0.25); background: rgba(214, 37, 56, 0.06); }

  .player-name {
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    font-weight: 800; letter-spacing: -0.025em;
    line-height: 1.05; margin: 0 0 0.6rem;
  }
  .player-meta {
    display: flex; gap: 0.5rem; align-items: center;
    font-size: 0.95rem; color: var(--text-muted);
  }
  .player-meta .sep { color: var(--text-dim); }

  .summary-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: 2rem;
  }
  .summary-card {
    display: flex; flex-direction: column; gap: 0.3rem;
    padding: 1.1rem 1.2rem;
    background: var(--surface);
  }
  .summary-card.primary { background: var(--surface-2); }
  .sc-label { font-size: 0.68rem; color: var(--text-muted); letter-spacing: 0.1em; }
  .sc-value {
    font-size: 1.6rem; font-weight: 700;
    color: var(--text); line-height: 1;
  }
  .summary-card.primary .sc-value { color: var(--accent); }

  .panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    margin-bottom: 2rem;
    overflow: hidden;
  }
  .panel-head {
    display: flex; align-items: baseline; justify-content: space-between;
    padding: 1rem 1.3rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg-elev);
  }
  .panel-head h2 { font-size: 1.05rem; font-weight: 700; margin: 0; }
  .panel-sub { font-size: 0.68rem; color: var(--text-dim); letter-spacing: 0.1em; }

  .pct-list { padding: 0.5rem 1.3rem; }
  .pct-row {
    display: grid;
    grid-template-columns: 130px 1fr 80px;
    align-items: center;
    gap: 1rem;
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--border);
  }
  .pct-row:last-child { border-bottom: none; }
  .pct-label { font-size: 0.82rem; color: var(--text); font-weight: 500; }
  .pct-track {
    position: relative; height: 22px;
    background: var(--surface-3);
    border-radius: 100px; overflow: visible;
  }
  .pct-grid { position: absolute; inset: 0; pointer-events: none; }
  .pct-tick {
    position: absolute; top: 0; bottom: 0; width: 1px;
    background: rgba(0,0,0,0.06);
  }
  .pct-bar {
    position: absolute; left: 0; top: 0; bottom: 0;
    border-radius: 100px;
    transition: width 0.5s ease;
    opacity: 0.25;
  }
  .pct-dot {
    position: absolute;
    top: 50%; transform: translateY(-50%);
    width: 30px; height: 30px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 0 0 3px var(--surface), 0 2px 6px rgba(0,0,0,0.12);
    transition: left 0.5s ease, background 0.3s ease;
  }
  .pct-num { font-size: 0.72rem; font-weight: 700; color: white; }
  .pct-value {
    text-align: right;
    font-size: 0.88rem; font-weight: 600;
    color: var(--text);
  }
  .pct-legend {
    display: flex; justify-content: center; gap: 1rem; align-items: center;
    padding: 0.8rem 1.3rem;
    border-top: 1px solid var(--border);
    font-size: 0.65rem; color: var(--text-dim);
    letter-spacing: 0.1em;
  }
  .leg-bar {
    width: 200px; height: 6px; border-radius: 100px;
    background: linear-gradient(90deg, var(--sv-blue), var(--sv-cyan), var(--sv-neutral), var(--sv-yellow), var(--sv-orange), var(--sv-red));
  }
  .leg-mid { color: var(--text-muted); }

  .arsenal-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
  .arsenal-table th {
    text-align: left;
    padding: 0.7rem 1.3rem;
    font-family: var(--font-mono);
    font-size: 0.65rem; font-weight: 600;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    border-bottom: 1px solid var(--border);
    background: var(--bg-elev);
  }
  .arsenal-table th.num, .arsenal-table td.num { text-align: right; }
  .arsenal-table th.dist, .arsenal-table td.dist { width: 180px; }
  .arsenal-table td {
    padding: 0.85rem 1.3rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }
  .arsenal-table tr:last-child td { border-bottom: none; }
  .arsenal-table tr:hover td { background: var(--surface-2); }

  .pitch-cell { display: flex; align-items: center; gap: 0.7rem; }
  .pitch-dot {
    width: 12px; height: 12px; border-radius: 50%;
    box-shadow: 0 0 0 2px rgba(0,0,0,0.05);
  }
  .pitch-name { font-weight: 600; color: var(--text); }
  .pitch-sub { font-size: 0.65rem; color: var(--text-dim); letter-spacing: 0.1em; }

  .dist-bars { display: flex; flex-direction: column; gap: 3px; }
  .dist-bar {
    height: 5px; width: var(--w);
    background: var(--c, var(--pitch-default));
    border-radius: 100px; max-width: 100%;
  }
  .dist-bar.whiff-bar { background: var(--sv-cyan); opacity: 0.85; }
  .dist-bar.hh-bar { background: var(--sv-orange); opacity: 0.85; }

  .arsenal-legend {
    display: flex; gap: 1.5rem; padding: 0.8rem 1.3rem;
    border-top: 1px solid var(--border);
    font-size: 0.65rem; color: var(--text-dim);
    letter-spacing: 0.1em;
  }
  .arsenal-legend span { display: inline-flex; align-items: center; gap: 0.4rem; }
  .leg-dot {
    width: 8px; height: 8px; border-radius: 50%;
    display: inline-block;
  }

  .footer-meta {
    text-align: right;
    font-size: 0.65rem; color: var(--text-dim);
    letter-spacing: 0.1em; margin-top: 1.5rem;
  }

  @media (max-width: 720px) {
    .pct-row { grid-template-columns: 90px 1fr 60px; gap: 0.6rem; }
    .pct-label { font-size: 0.75rem; }
    .arsenal-table th, .arsenal-table td { padding: 0.6rem 0.8rem; }
    .arsenal-table th.dist, .arsenal-table td.dist { display: none; }
  }
</style>
