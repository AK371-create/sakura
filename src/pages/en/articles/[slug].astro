---
import Layout from "../../../layouts/Layout.astro";

export async function getStaticPaths() {
  const modules = import.meta.glob("../../../content/articles/*.json", { eager: true });
  const articles = Object.values(modules).map((m: any) => m.default)
    .sort((a: any, b: any) => (a.date < b.date ? 1 : -1));
  return articles.map((article: any, i: number) => ({
    params: { slug: article.slug },
    props: {
      article,
      prev: articles[i - 1] ?? null,
      next: articles[i + 1] ?? null,
      related: articles
        .filter((x: any) => x.slug !== article.slug && x.category === article.category)
        .slice(0, 3),
    },
  }));
}

const { article, prev, next, related } = Astro.props;

const categoryLabels: Record<string, string> = {
  player: "Player", statcast: "Statcast", history: "History", rivalry: "Rivalry",
  rules: "Rules", team: "Team", prospects: "Prospects", culture: "Culture", market: "Market",
};
const catLabel = categoryLabels[article.category] ?? article.category;

const wordCount = article.body_en.join(" ").split(/\s+/).length;
const readMin = Math.max(1, Math.round(wordCount / 200));
---
<Layout
  title={article.title_en}
  description={article.summary_en}
  lang="en"
  currentPath={`/en/articles/${article.slug}/`}
>
  <nav class="breadcrumb">
    <a href="/en/articles/">← All articles</a>
  </nav>

  <article class="article">
    <header class="article-header">
      <div class="meta">
        <span class="cat">{catLabel}</span>
        <span class="date">{article.date}</span>
        <span class="dot">·</span>
        <span class="read">{readMin} min read</span>
      </div>
      <h1 class="article-title">{article.title_en}</h1>
      <p class="article-summary">{article.summary_en}</p>
    </header>

    <div class="article-body">
      {article.body_en.map((p: string, i: number) => (
        <p class:list={[{ "first-paragraph": i === 0 }]}>{p}</p>
      ))}
    </div>

    <footer class="article-footer">
      <div class="tags">
        {article.tags.map((t: string) => <span class="tag">#{t}</span>)}
      </div>
    </footer>
  </article>

  {(prev || next) && (
    <nav class="pager" aria-label="Article navigation">
      {prev ? (
        <a class="pager-link prev" href={`/en/articles/${prev.slug}/`}>
          <span class="pager-label">← Newer</span>
          <span class="pager-title">{prev.title_en}</span>
        </a>
      ) : <div></div>}
      {next ? (
        <a class="pager-link next" href={`/en/articles/${next.slug}/`}>
          <span class="pager-label">Older →</span>
          <span class="pager-title">{next.title_en}</span>
        </a>
      ) : <div></div>}
    </nav>
  )}

  {related.length > 0 && (
    <section class="related">
      <h2 class="related-heading">Related</h2>
      <div class="related-grid">
        {related.map((r: any) => (
          <a class="related-card" href={`/en/articles/${r.slug}/`}>
            <span class="related-cat">{categoryLabels[r.category] ?? r.category}</span>
            <span class="related-title">{r.title_en}</span>
            <span class="related-date">{r.date}</span>
          </a>
        ))}
      </div>
    </section>
  )}
</Layout>

<style>
  .breadcrumb { margin-bottom: 1.5rem; font-size: 0.88rem; }
  .breadcrumb a { color: var(--text-muted); }
  .breadcrumb a:hover { color: var(--accent); }

  .article {
    max-width: var(--reading-width);
    margin: 0 auto;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    padding: 2.5rem 2.2rem;
  }

  .article-header { margin-bottom: 2rem; }
  .meta {
    display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap;
    font-size: 0.8rem; color: var(--text-muted);
    margin-bottom: 1.2rem;
  }
  .cat {
    background: var(--rose-100); color: var(--rose-700);
    padding: 0.18rem 0.7rem; border-radius: 100px;
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.05em;
  }
  .date { font-variant-numeric: tabular-nums; }
  .dot { opacity: 0.4; }
  .read { font-style: italic; }

  .article-title {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 3.5vw, 2.3rem);
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.015em;
    margin: 0 0 1rem;
  }
  .article-summary {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin: 0;
    padding: 1rem 1.2rem;
    background: var(--rose-50);
    border-left: 3px solid var(--rose-300);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .article-body { font-size: 1.04rem; line-height: 1.85; color: var(--ink-700); }
  .article-body p { margin: 0 0 1.2rem; }
  .article-body p.first-paragraph::first-letter {
    font-family: var(--font-display);
    font-size: 3.4rem;
    line-height: 0.9;
    float: left;
    padding: 0.3rem 0.5rem 0 0;
    color: var(--accent);
    font-weight: 700;
  }

  .article-footer { margin-top: 2.2rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
  .tags { display: flex; gap: 0.45rem; flex-wrap: wrap; }
  .tag {
    font-size: 0.78rem; color: var(--text-muted);
    background: var(--rose-50);
    padding: 0.2rem 0.6rem; border: 1px solid var(--border);
    border-radius: 4px;
  }

  .pager {
    max-width: var(--reading-width);
    margin: 2rem auto 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
  }
  .pager-link {
    display: flex; flex-direction: column; gap: 0.4rem;
    padding: 1rem 1.2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text);
    transition: all 0.18s ease;
  }
  .pager-link:hover {
    background: var(--rose-50); border-color: var(--rose-200);
    text-decoration: none; transform: translateY(-1px);
  }
  .pager-link.next { text-align: right; }
  .pager-label { font-size: 0.78rem; color: var(--text-muted); font-weight: 500; }
  .pager-title {
    font-family: var(--font-display);
    font-size: 0.95rem; font-weight: 600;
    color: var(--text); line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related { max-width: var(--reading-width); margin: 3rem auto 0; }
  .related-heading {
    font-size: 1.1rem; margin: 0 0 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--border);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.7rem;
  }
  .related-card {
    display: flex; flex-direction: column; gap: 0.4rem;
    padding: 0.95rem 1.05rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text);
    transition: all 0.18s ease;
  }
  .related-card:hover {
    border-color: var(--rose-200);
    background: var(--rose-50);
    text-decoration: none; transform: translateY(-1px);
  }
  .related-cat {
    align-self: flex-start;
    background: var(--rose-100); color: var(--rose-700);
    padding: 0.1rem 0.5rem; border-radius: 100px;
    font-size: 0.65rem; font-weight: 600; letter-spacing: 0.04em;
  }
  .related-title {
    font-family: var(--font-display);
    font-size: 0.92rem; font-weight: 600;
    line-height: 1.45;
  }
  .related-date {
    font-size: 0.75rem; color: var(--text-muted);
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 640px) {
    .article { padding: 1.5rem 1.3rem; }
    .article-body p.first-paragraph::first-letter { font-size: 2.6rem; }
    .pager { grid-template-columns: 1fr; }
    .pager-link.next { text-align: left; }
  }
</style>
