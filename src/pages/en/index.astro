---
import Layout from "../../layouts/Layout.astro";
import PlayerCard from "../../components/PlayerCard.astro";
import ohtani from "../../content/players/ohtani.json";
import imanaga from "../../content/players/imanaga.json";
import murakami from "../../content/players/murakami.json";

const players = [ohtani, imanaga, murakami];

const articleModules = import.meta.glob("../../content/articles/*.json", { eager: true });
const articles = Object.values(articleModules)
  .map((m: any) => m.default)
  .sort((a: any, b: any) => (a.date < b.date ? 1 : -1));
const featured = articles.slice(0, 4);
---
<Layout title="SakuraBall" description="Season stats, Statcast metrics, and analysis for Japanese MLB players" lang="en" currentPath="/">
  <section class="hero">
    <div class="hero-eyebrow">2026 SEASON</div>
    <h1 class="hero-title">Japanese MLB,<br />read through the numbers.</h1>
    <p class="hero-lede">
      Season stats, Statcast metrics, and pitch-arsenal analysis in one place —
      from Ohtani's two-way game, to Murakami's MLB adjustment, to Imanaga's pitch strategy.
    </p>
    <div class="hero-cta">
      <a class="btn btn-primary" href="#players">View players</a>
      <a class="btn btn-ghost" href="/en/articles/">Read articles</a>
    </div>
  </section>

  <section id="players" class="section">
    <div class="section-header">
      <h2>Featured players</h2>
      <span class="section-count">{players.length} players</span>
    </div>
    <div class="player-grid">
      {players.map((p) => (
        <PlayerCard player={p} lang="en" href={`/en/players/${p.key}/`} />
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Latest articles</h2>
      <a class="section-more" href="/en/articles/">View all →</a>
    </div>
    <div class="article-grid">
      {featured.map((a: any) => (
        <a class="article-tile" href={`/en/articles/${a.slug}/`}>
          <div class="tile-meta">
            <span class="tile-date">{a.date}</span>
            <span class="tile-cat">{a.category}</span>
          </div>
          <div class="tile-title">{a.title_en}</div>
          <div class="tile-summary">{a.summary_en}</div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .hero { padding: 3rem 0 2.5rem; text-align: center; }
  .hero-eyebrow {
    display: inline-block;
    font-size: 0.75rem; font-weight: 600;
    letter-spacing: 0.2em; color: var(--accent);
    background: var(--rose-100);
    padding: 0.3rem 0.9rem; border-radius: 100px;
    margin-bottom: 1.4rem;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4.5vw, 2.8rem);
    font-weight: 700; line-height: 1.3;
    margin: 0 0 1.2rem;
    letter-spacing: -0.02em;
  }
  .hero-lede {
    max-width: 580px; margin: 0 auto 2rem;
    font-size: 1.02rem; color: var(--text-muted);
    line-height: 1.85;
  }
  .hero-cta { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; }
  .btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 0.75rem 1.6rem;
    font-size: 0.95rem; font-weight: 600;
    border-radius: 100px;
    transition: all 0.18s ease;
  }
  .btn-primary {
    background: var(--accent); color: white;
    box-shadow: 0 4px 14px rgba(200, 81, 110, 0.3);
  }
  .btn-primary:hover {
    background: var(--rose-600); color: white; text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(200, 81, 110, 0.4);
  }
  .btn-ghost {
    color: var(--text);
    border: 1px solid var(--rose-200);
    background: rgba(255, 255, 255, 0.5);
  }
  .btn-ghost:hover { background: var(--rose-100); text-decoration: none; }

  .section { margin-top: 3.5rem; }
  .section-header {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: 1.4rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--border);
  }
  .section-header h2 { font-size: 1.4rem; font-weight: 700; margin: 0; }
  .section-count { font-size: 0.85rem; color: var(--text-muted); }
  .section-more { font-size: 0.9rem; font-weight: 500; }

  .player-grid { display: grid; gap: 0.85rem; }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.85rem;
  }
  .article-tile {
    display: flex; flex-direction: column; gap: 0.5rem;
    padding: 1.1rem 1.2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    color: var(--text);
    box-shadow: var(--shadow-sm);
    transition: all 0.18s ease;
  }
  .article-tile:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--rose-200);
    text-decoration: none;
  }
  .tile-meta { display: flex; gap: 0.5rem; align-items: center; font-size: 0.75rem; }
  .tile-date { color: var(--text-muted); font-variant-numeric: tabular-nums; }
  .tile-cat {
    background: var(--rose-100); color: var(--rose-700);
    padding: 0.1rem 0.55rem; border-radius: 100px;
    font-weight: 600; letter-spacing: 0.04em;
    text-transform: uppercase; font-size: 0.65rem;
  }
  .tile-title {
    font-family: var(--font-display);
    font-size: 1.05rem; font-weight: 700;
    line-height: 1.45;
  }
  .tile-summary {
    font-size: 0.85rem; color: var(--text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
