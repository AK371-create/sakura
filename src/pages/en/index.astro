---
import Layout from "../../layouts/Layout.astro";
import PlayerCard from "../../components/PlayerCard.astro";
import ohtani from "../../content/players/ohtani.json";
import imanaga from "../../content/players/imanaga.json";
import murakami from "../../content/players/murakami.json";

const players = [ohtani, imanaga, murakami];

const articleModules = import.meta.glob("../../content/articles/*.json", { eager: true });
const articles = Object.values(articleModules)
  .map((m: any) => m.default)
  .sort((a: any, b: any) => (a.date < b.date ? 1 : -1));
const featured = articles.slice(0, 6);

const categoryLabels: Record<string, string> = {
  player: "PLAYER", statcast: "STATCAST", history: "HISTORY", rivalry: "MATCHUP",
  rules: "RULES", team: "TEAM", prospects: "PROSPECT", culture: "CULTURE", market: "MARKET",
};

const stats = {
  players: players.length,
  articles: articles.length,
  lastUpdate: articles[0]?.date ?? "",
};
---
<Layout title="SakuraBall" description="Season stats, Statcast metrics, and analysis for Japanese MLB players" lang="en" currentPath="/">
  <section class="hero">
    <div class="hero-eyebrow mono">JAPANESE MLB // 2026 SEASON</div>
    <h1 class="hero-title">Japanese MLB,<br /><span class="accent">read as data.</span></h1>
    <p class="hero-lede">
      Statcast metrics, pitch arsenals, and percentile breakdowns for Japanese major leaguers.
    </p>
    <div class="hero-stats">
      <div class="hstat">
        <div class="hstat-val mono">{stats.players}</div>
        <div class="hstat-lbl mono">PLAYERS</div>
      </div>
      <div class="hstat">
        <div class="hstat-val mono">{stats.articles}</div>
        <div class="hstat-lbl mono">ARTICLES</div>
      </div>
      <div class="hstat">
        <div class="hstat-val mono">{stats.lastUpdate}</div>
        <div class="hstat-lbl mono">LAST UPDATE</div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div class="section-head-main">
        <span class="section-num mono">01</span>
        <h2>Players</h2>
      </div>
      <span class="mono section-count">N={players.length}</span>
    </div>
    <div class="player-grid">
      {players.map((p) => (
        <PlayerCard player={p} lang="en" href={`/en/players/${p.key}/`} />
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div class="section-head-main">
        <span class="section-num mono">02</span>
        <h2>Analysis</h2>
      </div>
      <a class="section-link mono" href="/en/articles/">VIEW ALL →</a>
    </div>
    <div class="article-grid">
      {featured.map((a: any) => (
        <a class="article-tile" href={`/en/articles/${a.slug}/`}>
          <div class="tile-meta mono">
            <span class="tile-cat">{categoryLabels[a.category] ?? a.category.toUpperCase()}</span>
            <span class="tile-date">{a.date}</span>
          </div>
          <div class="tile-title">{a.title_en}</div>
          <div class="tile-summary">{a.summary_en}</div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .hero { padding: 3rem 0 2.5rem; margin-bottom: 1rem; }
  .hero-eyebrow {
    font-size: 0.72rem; font-weight: 600;
    color: var(--accent); letter-spacing: 0.2em;
    margin-bottom: 1.2rem;
  }
  .hero-title {
    font-size: clamp(2.2rem, 5.5vw, 3.8rem);
    font-weight: 800; line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 1.2rem;
  }
  .hero-title .accent { color: var(--accent); }
  .hero-lede {
    max-width: 560px;
    font-size: 1.02rem; color: var(--text-muted);
    line-height: 1.7; margin: 0 0 2rem;
  }
  .hero-stats {
    display: flex; gap: 2rem; flex-wrap: wrap;
    padding: 1.2rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .hstat { display: flex; flex-direction: column; gap: 0.25rem; }
  .hstat-val {
    font-size: 1.5rem; font-weight: 700;
    color: var(--text); line-height: 1;
  }
  .hstat-lbl {
    font-size: 0.65rem; color: var(--text-dim);
    letter-spacing: 0.15em;
  }

  .section { margin-top: 3rem; }
  .section-head {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-bottom: 1.2rem; padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--border);
  }
  .section-head-main { display: flex; align-items: baseline; gap: 0.7rem; }
  .section-num { font-size: 0.8rem; color: var(--text-dim); letter-spacing: 0.08em; }
  .section-head h2 { font-size: 1.3rem; font-weight: 700; margin: 0; letter-spacing: -0.01em; }
  .section-count { font-size: 0.7rem; color: var(--text-dim); letter-spacing: 0.08em; }
  .section-link {
    font-size: 0.72rem; font-weight: 600;
    color: var(--text-muted); letter-spacing: 0.1em;
  }
  .section-link:hover { color: var(--accent); text-decoration: none; }

  .player-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 0.8rem;
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 0.8rem;
  }
  .article-tile {
    display: flex; flex-direction: column; gap: 0.55rem;
    padding: 1.1rem 1.2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text);
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .article-tile:hover {
    border-color: var(--border-strong);
    background: var(--surface-2);
    text-decoration: none;
  }
  .tile-meta {
    display: flex; gap: 0.8rem; align-items: center;
    font-size: 0.65rem; letter-spacing: 0.08em;
  }
  .tile-cat { color: var(--accent); font-weight: 700; }
  .tile-date { color: var(--text-dim); }
  .tile-title {
    font-size: 1rem; font-weight: 700;
    line-height: 1.4; color: var(--text);
  }
  .tile-summary {
    font-size: 0.83rem; color: var(--text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
