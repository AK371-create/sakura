---
export interface Props {
  title: string;
  description?: string;
  lang?: "ja" | "en";
  currentPath?: string;
  ogImage?: string;
  ogType?: "website" | "article" | "profile";
  jsonLd?: object | object[];
  publishedDate?: string;
  modifiedDate?: string;
}
const {
  title,
  description = "",
  lang = "ja",
  currentPath = "/",
  ogImage,
  ogType = "website",
  jsonLd,
  publishedDate,
  modifiedDate,
} = Astro.props;
const siteName = "SakuraBall";
const siteTagline = lang === "ja" ? "日本人MLBデータ分析" : "Japanese MLB Analytics";
const SITE_ORIGIN = "https://sakuraballpark.com";

let otherLangUrl: string;
if (lang === "ja") {
  otherLangUrl = currentPath === "/" ? "/en/" : "/en" + currentPath;
} else {
  otherLangUrl = currentPath.replace(/^\/en/, "") || "/";
}
const otherLangLabel = lang === "ja" ? "EN" : "JA";

const navLinks = lang === "ja"
  ? [
      { href: "/", label: "ホーム" },
      { href: "/articles/", label: "記事" },
    ]
  : [
      { href: "/en/", label: "Home" },
      { href: "/en/articles/", label: "Analysis" },
    ];

const fullTitle = title === siteName ? `${siteName} · ${siteTagline}` : `${title} · ${siteName}`;
const canonicalUrl = SITE_ORIGIN + currentPath;
const altLangUrl = SITE_ORIGIN + otherLangUrl;
const ogImageUrl = ogImage ? (ogImage.startsWith("http") ? ogImage : SITE_ORIGIN + ogImage) : SITE_ORIGIN + "/og-default.svg";

// Build base WebSite + Organization JSON-LD always
const baseLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": siteName,
    "alternateName": "Sakura Ball Park",
    "url": SITE_ORIGIN,
    "inLanguage": lang === "ja" ? "ja-JP" : "en-US",
    "description": lang === "ja"
      ? "日本人メジャーリーガーのシーズン成績、Statcast指標、分析記事を掲載"
      : "Season stats, Statcast metrics, and analysis for Japanese MLB players",
    "potentialAction": {
      "@type": "SearchAction",
      "target": SITE_ORIGIN + "/articles/?q={search_term_string}",
      "query-input": "required name=search_term_string",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": siteName,
    "url": SITE_ORIGIN,
    "logo": SITE_ORIGIN + "/og-default.svg",
  },
];
const allJsonLd = [...baseLd, ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])];
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}

    <!-- Canonical & alternate languages -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={lang === "ja" ? "ja" : "en"} href={canonicalUrl} />
    <link rel="alternate" hreflang={lang === "ja" ? "en" : "ja"} href={altLangUrl} />
    <link rel="alternate" hreflang="x-default" href={lang === "ja" ? canonicalUrl : altLangUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={lang === "ja" ? "ja_JP" : "en_US"} />
    <meta property="og:locale:alternate" content={lang === "ja" ? "en_US" : "ja_JP"} />
    {publishedDate && <meta property="article:published_time" content={publishedDate} />}
    {modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="theme-color" content="#faf8f7" />
    <meta name="color-scheme" content="light" />

    <!-- JSON-LD -->
    {allJsonLd.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&family=Noto+Sans+JP:wght@400;500;700;800&display=swap"
    />
  </head>
  <body>
    <div class="grid-bg" aria-hidden="true"></div>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href={lang === "ja" ? "/" : "/en/"}>
          <span class="brand-mark" aria-hidden="true">
            <svg viewBox="0 0 32 32" width="22" height="22">
              <circle cx="16" cy="16" r="14" fill="none" stroke="currentColor" stroke-width="1.5" />
              <path d="M16 2 C 12 8, 12 14, 16 16 C 20 14, 20 8, 16 2 Z" fill="currentColor" />
              <path d="M16 30 C 20 24, 20 18, 16 16 C 12 18, 12 24, 16 30 Z" fill="currentColor" opacity="0.6" />
            </svg>
          </span>
          <span class="brand-text">
            <span class="brand-name">SakuraBall</span>
            <span class="brand-tagline">{siteTagline}</span>
          </span>
        </a>
        <nav class="primary-nav">
          {navLinks.map((l) => (
            <a href={l.href} class:list={["nav-link", { active: l.href === currentPath }]}>{l.label}</a>
          ))}
          <a href={otherLangUrl} class="lang-switch">{otherLangLabel}</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-cols">
          <div>
            <div class="footer-brand">SakuraBall</div>
            <div class="footer-meta">{lang === "ja" ? "日本人MLB選手の統計・分析" : "Japanese MLB stats & analysis"}</div>
          </div>
          <div class="footer-links">
            <a href={lang === "ja" ? "/" : "/en/"}>{lang === "ja" ? "ホーム" : "Home"}</a>
            <a href={lang === "ja" ? "/articles/" : "/en/articles/"}>{lang === "ja" ? "記事" : "Analysis"}</a>
            <a href={otherLangUrl}>{otherLangLabel === "EN" ? "English" : "日本語"}</a>
          </div>
        </div>
        <div class="footer-legal">© 2026 SakuraBall · {lang === "ja" ? "データは当該選手の公開統計を基に推定表示" : "Stats derived from publicly available sources"}</div>
      </div>
    </footer>

    <style is:global>
      :root {
        /* Savant-inspired light palette */
        --bg: #faf8f7;
        --bg-elev: #f4f1ef;
        --surface: #ffffff;
        --surface-2: #faf8f6;
        --surface-3: #f0ece9;
        --border: #e6e1dd;
        --border-strong: #d4cdc7;

        --text: #1a1614;
        --text-muted: #6b6360;
        --text-dim: #9c948f;

        /* Percentile palette: blue = poor, red = elite */
        --sv-red: #d62538;
        --sv-orange: #ed7c2c;
        --sv-yellow: #d9a92e;
        --sv-neutral: #9aa0a6;
        --sv-cyan: #2d97c4;
        --sv-blue: #2c5dd1;

        /* Semantic accent: MLB red */
        --accent: #d62538;
        --accent-hover: #b81d2d;

        /* Pitch type colors (MLB savant convention) */
        --pitch-ff: #ee4040; /* 4-seam */
        --pitch-ft: #e27000;
        --pitch-fs: #c1b700; /* splitter */
        --pitch-fc: #d22222; /* cutter */
        --pitch-si: #ff7700;
        --pitch-sl: #ddd800; /* slider */
        --pitch-cu: #00d1d1; /* curve */
        --pitch-ch: #20b040; /* change */
        --pitch-kc: #5a60e0;
        --pitch-default: #6686c0;

        --font-sans: "Inter", "Noto Sans JP", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        --font-mono: "JetBrains Mono", "SF Mono", Consolas, Monaco, monospace;

        --radius-sm: 4px;
        --radius-md: 8px;
        --radius-lg: 12px;

        --content-width: 1120px;
        --reading-width: 720px;

        --shadow-sm: 0 1px 2px rgba(20, 14, 12, 0.04), 0 1px 3px rgba(20, 14, 12, 0.06);
        --shadow-md: 0 8px 24px rgba(20, 14, 12, 0.08), 0 2px 6px rgba(20, 14, 12, 0.05);
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      html, body { margin: 0; padding: 0; }
      body {
        font-family: var(--font-sans);
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        min-height: 100vh;
        position: relative;
      }

      /* Subtle grid background */
      .grid-bg {
        position: fixed; inset: 0; z-index: -1;
        background-image:
          linear-gradient(rgba(0,0,0,0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0,0,0,0.025) 1px, transparent 1px);
        background-size: 40px 40px;
        background-position: center;
        mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);
        -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);
        pointer-events: none;
      }
      body::before {
        content: ""; position: fixed; inset: 0; z-index: -2;
        background:
          radial-gradient(circle at 15% 0%, rgba(214, 37, 56, 0.04), transparent 40%),
          radial-gradient(circle at 85% 100%, rgba(44, 93, 209, 0.03), transparent 45%);
      }

      a { color: var(--accent); text-decoration: none; transition: color 0.15s ease; }
      a:hover { color: var(--accent-hover); }

      h1, h2, h3, h4 {
        color: var(--text);
        letter-spacing: -0.01em;
        line-height: 1.25;
        margin-top: 0;
        font-weight: 700;
      }

      code, .mono { font-family: var(--font-mono); font-feature-settings: "tnum" 1, "ss01" 1; }

      ::selection { background: rgba(214, 37, 56, 0.25); color: var(--text); }

      /* === Header === */
      .site-header {
        position: sticky; top: 0; z-index: 50;
        backdrop-filter: saturate(180%) blur(12px);
        -webkit-backdrop-filter: saturate(180%) blur(12px);
        background: rgba(250, 248, 247, 0.85);
        border-bottom: 1px solid var(--border);
      }
      .header-inner {
        max-width: var(--content-width); margin: 0 auto;
        display: flex; justify-content: space-between; align-items: center;
        padding: 0.85rem 1.5rem;
        gap: 1rem;
      }
      .brand {
        display: flex; align-items: center; gap: 0.6rem;
        color: var(--text);
      }
      .brand:hover { color: var(--accent); text-decoration: none; }
      .brand-mark { color: var(--accent); display: inline-flex; }
      .brand-text { display: flex; flex-direction: column; line-height: 1.1; }
      .brand-name {
        font-weight: 800;
        font-size: 1rem;
        letter-spacing: 0.01em;
      }
      .brand-tagline {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--text-muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .primary-nav { display: flex; align-items: center; gap: 0.3rem; }
      .nav-link {
        padding: 0.5rem 0.9rem;
        color: var(--text-muted);
        font-size: 0.85rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        border-radius: var(--radius-sm);
        transition: all 0.15s ease;
      }
      .nav-link:hover { color: var(--text); background: var(--surface); text-decoration: none; }
      .nav-link.active { color: var(--accent); }
      .lang-switch {
        margin-left: 0.3rem;
        padding: 0.35rem 0.7rem;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        color: var(--text-muted);
        font-family: var(--font-mono);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        transition: all 0.15s ease;
      }
      .lang-switch:hover {
        color: var(--accent);
        border-color: var(--accent);
        background: rgba(214, 37, 56, 0.08);
        text-decoration: none;
      }

      main {
        max-width: var(--content-width);
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
      }

      /* === Footer === */
      .site-footer {
        border-top: 1px solid var(--border);
        margin-top: 4rem;
        background: var(--bg-elev);
      }
      .footer-inner {
        max-width: var(--content-width);
        margin: 0 auto;
        padding: 2rem 1.5rem 1.5rem;
      }
      .footer-cols {
        display: flex; justify-content: space-between; align-items: flex-start;
        gap: 2rem; flex-wrap: wrap;
        margin-bottom: 1.5rem;
      }
      .footer-brand { font-weight: 800; color: var(--accent); letter-spacing: 0.02em; }
      .footer-meta {
        font-family: var(--font-mono);
        color: var(--text-muted); font-size: 0.75rem;
        letter-spacing: 0.04em;
        margin-top: 0.2rem;
      }
      .footer-links { display: flex; gap: 1.2rem; }
      .footer-links a { color: var(--text-muted); font-size: 0.85rem; }
      .footer-links a:hover { color: var(--text); }
      .footer-legal {
        padding-top: 1rem;
        border-top: 1px solid var(--border);
        font-family: var(--font-mono);
        color: var(--text-dim); font-size: 0.72rem;
        letter-spacing: 0.03em;
      }

      @media (max-width: 640px) {
        .brand-tagline { display: none; }
        .header-inner { padding: 0.7rem 1rem; }
        main { padding: 1.2rem 1rem 3rem; }
        .nav-link { padding: 0.4rem 0.6rem; font-size: 0.8rem; }
      }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        * { transition-duration: 0.01ms !important; }
      }
    </style>
  </body>
</html>
