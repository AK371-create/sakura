---
export interface Props {
  title: string;
  description?: string;
  lang?: "ja" | "en";
  currentPath?: string;
}
const { title, description = "", lang = "ja", currentPath = "/" } = Astro.props;
const siteName = lang === "ja" ? "SakuraBall" : "SakuraBall";
const siteTagline = lang === "ja" ? "日本人メジャーリーガー分析" : "Japanese MLB Analytics";

let otherLangUrl: string;
if (lang === "ja") {
  otherLangUrl = currentPath === "/" ? "/en/" : "/en" + currentPath;
} else {
  otherLangUrl = currentPath.replace(/^\/en/, "") || "/";
}
const otherLangLabel = lang === "ja" ? "EN" : "JA";

const navLinks = lang === "ja"
  ? [
      { href: "/", label: "ホーム" },
      { href: "/articles/", label: "記事" },
    ]
  : [
      { href: "/en/", label: "Home" },
      { href: "/en/articles/", label: "Articles" },
    ];

const fullTitle = title === siteName ? `${siteName} — ${siteTagline}` : `${title} | ${siteName}`;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#fbeef1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Serif+JP:wght@500;700&family=Noto+Sans+JP:wght@400;500;700&display=swap"
    />
  </head>
  <body>
    <div class="petals" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
    </div>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href={lang === "ja" ? "/" : "/en/"}>
          <span class="brand-mark" aria-hidden="true">
            <svg viewBox="0 0 32 32" width="28" height="28">
              <g fill="currentColor">
                <circle cx="16" cy="16" r="2.4" />
                <path d="M16 4 c1.5 3 1.5 6 0 8 c-1.5-2-1.5-5 0-8z" />
                <path d="M16 28 c1.5-3 1.5-6 0-8 c-1.5 2-1.5 5 0 8z" />
                <path d="M4 16 c3-1.5 6-1.5 8 0 c-2 1.5-5 1.5-8 0z" />
                <path d="M28 16 c-3-1.5-6-1.5-8 0 c2 1.5 5 1.5 8 0z" />
                <path d="M7.5 7.5 c2.6.4 5 1.7 6.5 3.6 c-2.4-.5-4.7-1.7-6.5-3.6z" />
                <path d="M24.5 24.5 c-2.6-.4-5-1.7-6.5-3.6 c2.4.5 4.7 1.7 6.5 3.6z" />
                <path d="M24.5 7.5 c-.4 2.6-1.7 5-3.6 6.5 c.5-2.4 1.7-4.7 3.6-6.5z" />
                <path d="M7.5 24.5 c.4-2.6 1.7-5 3.6-6.5 c-.5 2.4-1.7 4.7-3.6 6.5z" />
              </g>
            </svg>
          </span>
          <span class="brand-text">
            <span class="brand-name">SakuraBall</span>
            <span class="brand-tagline">{siteTagline}</span>
          </span>
        </a>
        <nav class="primary-nav">
          {navLinks.map((l) => (
            <a href={l.href} class:list={["nav-link", { active: l.href === currentPath }]}>{l.label}</a>
          ))}
          <a href={otherLangUrl} class="lang-switch" aria-label={lang === "ja" ? "Switch to English" : "日本語に切り替え"}>
            {otherLangLabel}
          </a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">SakuraBall</div>
        <div class="footer-meta">© 2026 SakuraBall. {lang === "ja" ? "日本人MLB選手の分析・記事" : "Japanese MLB analysis & articles"}.</div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --rose-50: #fdf5f7;
    --rose-100: #fbeef1;
    --rose-200: #f5d8df;
    --rose-300: #ecb6c2;
    --rose-400: #d88296;
    --rose-500: #c8516e;
    --rose-600: #a73a55;
    --rose-700: #7d2840;

    --ink-900: #1d1419;
    --ink-700: #3d2c33;
    --ink-500: #6b5a61;
    --ink-300: #a89aa0;
    --ink-100: #ead8de;

    --cream: #fffbfb;
    --paper: #ffffff;

    --gold: #c89b3c;

    --bg: var(--rose-50);
    --surface: var(--paper);
    --surface-2: var(--cream);
    --text: var(--ink-900);
    --text-muted: var(--ink-500);
    --border: var(--ink-100);
    --accent: var(--rose-500);
    --accent-soft: var(--rose-200);

    --font-sans: "Inter", "Noto Sans JP", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    --font-serif: "Noto Serif JP", "Hiragino Mincho ProN", "Yu Mincho", Georgia, serif;
    --font-display: var(--font-serif);

    --shadow-sm: 0 1px 2px rgba(125, 40, 64, 0.04), 0 1px 3px rgba(125, 40, 64, 0.06);
    --shadow-md: 0 4px 12px rgba(125, 40, 64, 0.08), 0 2px 4px rgba(125, 40, 64, 0.04);
    --shadow-lg: 0 12px 32px rgba(125, 40, 64, 0.12), 0 4px 8px rgba(125, 40, 64, 0.06);

    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 16px;
    --radius-xl: 24px;

    --content-width: 880px;
    --reading-width: 680px;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  html, body { margin: 0; padding: 0; }
  body {
    font-family: var(--font-sans);
    background:
      radial-gradient(circle at 0% 0%, rgba(236, 182, 194, 0.18), transparent 40%),
      radial-gradient(circle at 100% 100%, rgba(245, 216, 223, 0.25), transparent 50%),
      var(--bg);
    color: var(--text);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    min-height: 100vh;
    position: relative;
  }
  body::before {
    content: "";
    position: fixed; inset: 0; z-index: -1;
    background-image:
      linear-gradient(180deg, transparent 0%, rgba(253, 245, 247, 0.4) 100%);
    pointer-events: none;
  }

  a { color: var(--accent); text-decoration: none; transition: color 0.2s ease; }
  a:hover { color: var(--rose-700); }

  h1, h2, h3, h4 {
    font-family: var(--font-display);
    color: var(--text);
    letter-spacing: -0.01em;
    line-height: 1.3;
    margin-top: 0;
  }

  /* === Header === */
  .site-header {
    position: sticky; top: 0; z-index: 50;
    backdrop-filter: saturate(150%) blur(14px);
    -webkit-backdrop-filter: saturate(150%) blur(14px);
    background: rgba(255, 251, 251, 0.78);
    border-bottom: 1px solid rgba(234, 216, 222, 0.6);
  }
  .header-inner {
    max-width: var(--content-width); margin: 0 auto;
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.85rem 1.5rem;
    gap: 1rem;
  }
  .brand {
    display: flex; align-items: center; gap: 0.7rem;
    color: var(--text);
  }
  .brand:hover { color: var(--accent); text-decoration: none; }
  .brand-mark {
    color: var(--accent);
    display: inline-flex;
  }
  .brand-text { display: flex; flex-direction: column; line-height: 1.15; }
  .brand-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: -0.01em;
  }
  .brand-tagline {
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }
  .primary-nav {
    display: flex; align-items: center; gap: 0.4rem;
  }
  .nav-link {
    padding: 0.45rem 0.85rem;
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 500;
    border-radius: var(--radius-sm);
    transition: background 0.15s ease, color 0.15s ease;
  }
  .nav-link:hover { background: var(--rose-100); text-decoration: none; }
  .nav-link.active { color: var(--accent); }
  .lang-switch {
    margin-left: 0.4rem;
    padding: 0.4rem 0.7rem;
    border: 1px solid var(--rose-200);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    transition: all 0.15s ease;
  }
  .lang-switch:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
    text-decoration: none;
  }

  main {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }

  /* === Footer === */
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    background: rgba(255, 251, 251, 0.5);
  }
  .footer-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }
  .footer-brand {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.02em;
  }
  .footer-meta { color: var(--text-muted); font-size: 0.85rem; }

  /* === Decorative petals === */
  .petals {
    position: fixed; inset: 0;
    pointer-events: none;
    z-index: -1;
    overflow: hidden;
  }
  .petals span {
    position: absolute;
    display: block;
    width: 14px; height: 14px;
    background: radial-gradient(ellipse at center, var(--rose-300), var(--rose-200));
    border-radius: 50% 0 50% 0;
    opacity: 0.35;
    animation: drift 22s linear infinite;
  }
  .petals span:nth-child(1) { left: 10%; top: -5%; animation-delay: 0s; }
  .petals span:nth-child(2) { left: 30%; top: -10%; animation-delay: -6s; transform: scale(0.7); }
  .petals span:nth-child(3) { left: 55%; top: -8%; animation-delay: -12s; transform: scale(1.2); }
  .petals span:nth-child(4) { left: 78%; top: -6%; animation-delay: -3s; transform: scale(0.9); }
  .petals span:nth-child(5) { left: 92%; top: -12%; animation-delay: -16s; transform: scale(0.6); }
  @keyframes drift {
    0%   { transform: translateY(0) rotate(0deg); opacity: 0; }
    10%  { opacity: 0.35; }
    100% { transform: translateY(110vh) rotate(420deg); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .petals span { animation: none; opacity: 0.15; }
    html { scroll-behavior: auto; }
  }

  /* === Mobile === */
  @media (max-width: 640px) {
    .brand-tagline { display: none; }
    .header-inner { padding: 0.7rem 1rem; }
    main { padding: 1.5rem 1rem 3rem; }
    .nav-link { padding: 0.4rem 0.6rem; font-size: 0.85rem; }
  }
</style>
