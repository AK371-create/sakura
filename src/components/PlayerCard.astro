---
export interface Props {
  player: any;
  lang: "ja" | "en";
  href: string;
}
const { player, lang, href } = Astro.props;
const name = lang === "ja" ? player.name_jp : player.name_en;
const team = lang === "ja" ? player.team_jp : player.team_en;
const pos = lang === "ja" ? player.position_jp : player.position_en;
const hitting = player.basic?.hitting;
const pitching = player.basic?.pitching;
const savantHit = player.savant?.hitting;

const typeCode = lang === "ja"
  ? ({ two_way: "二刀流", batter: "野手", pitcher: "投手" }[player.type] ?? player.type)
  : ({ two_way: "TWO-WAY", batter: "BATTER", pitcher: "PITCHER" }[player.type] ?? player.type);

let leagueLabel: string;
if (player.level === "AAA") {
  leagueLabel = lang === "ja" ? "3A" : "AAA";
} else if (player.level === "FORMER") {
  leagueLabel = lang === "ja" ? "元MLB" : "FORMER";
} else if (lang === "ja") {
  leagueLabel = ({ NL: "ナ・リーグ", AL: "ア・リーグ" } as Record<string, string>)[player.league] ?? player.league;
} else {
  leagueLabel = player.league;
}

// Detect "no current-season appearance" for active MLB players
const CURRENT_SEASON = 2026;
const bs = player.basic_season ?? {};
const playerType = player.type;
const expected = playerType === "two_way" ? ["hitting", "pitching"] : (playerType === "batter" ? ["hitting"] : ["pitching"]);
const noCurrentSeason = player.level === "MLB" && expected.every((g: string) => bs[g] !== undefined && bs[g] !== CURRENT_SEASON);
const noCurrentLabel = lang === "ja" ? "今季出場なし" : "Not played";
---
<a class="player-card" href={href}>
  <div class="card-head">
    <div class="head-tags">
      <span class={`tag type type-${player.type}`}>{typeCode}</span>
      <span class:list={["tag league", `league-${player.league.toLowerCase()}`, { former: player.level === "FORMER" }]}>{leagueLabel}</span>
      {noCurrentSeason && <span class="tag no-current">{noCurrentLabel}</span>}
    </div>
    <div class="go" aria-hidden="true">→</div>
  </div>
  <div class="card-name">{name}</div>
  <div class="card-meta">
    <span>{team}</span>
    <span class="sep">·</span>
    <span>{pos}</span>
  </div>
  {noCurrentSeason ? (
    <div class="card-no-stats">
      {lang === "ja" ? "2026シーズンの出場なし" : "No 2026 season appearances"}
    </div>
  ) : (
    <div class="card-stats">
      {hitting && (
        <>
          <div class="stat"><div class="stat-label">{lang === "ja" ? "打率" : "AVG"}</div><div class="stat-value">{hitting.avg}</div></div>
          <div class="stat"><div class="stat-label">{lang === "ja" ? "本塁打" : "HR"}</div><div class="stat-value">{hitting.hr}</div></div>
          <div class="stat"><div class="stat-label">OPS</div><div class="stat-value">{hitting.ops}</div></div>
        </>
      )}
      {pitching && !hitting && (
        <>
          <div class="stat"><div class="stat-label">{lang === "ja" ? "防御率" : "ERA"}</div><div class="stat-value">{pitching.era}</div></div>
          <div class="stat"><div class="stat-label">{lang === "ja" ? "奪三振" : "SO"}</div><div class="stat-value">{pitching.so}</div></div>
          <div class="stat"><div class="stat-label">WHIP</div><div class="stat-value">{pitching.whip}</div></div>
        </>
      )}
      {pitching && hitting && (
        <div class="stat"><div class="stat-label">{lang === "ja" ? "防御率" : "ERA"}</div><div class="stat-value">{pitching.era}</div></div>
      )}
    </div>
  )}
  {savantHit && !noCurrentSeason && (
    <div class="card-spark">
      <div class="spark-item">
        <span class="spark-lbl">EV</span>
        <span class="spark-val">{savantHit.exit_velocity_avg}</span>
      </div>
      <div class="spark-item">
        <span class="spark-lbl">BRL%</span>
        <span class="spark-val">{savantHit.barrel_batted_rate}</span>
      </div>
      <div class="spark-item">
        <span class="spark-lbl">HH%</span>
        <span class="spark-val">{savantHit.hard_hit_percent}</span>
      </div>
      <div class="spark-item">
        <span class="spark-lbl">xwOBA</span>
        <span class="spark-val">{savantHit.xwoba}</span>
      </div>
    </div>
  )}
</a>

<style>
  .player-card {
    position: relative;
    display: flex; flex-direction: column;
    padding: 1.2rem 1.3rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text);
    box-shadow: var(--shadow-sm);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    overflow: hidden;
  }
  .player-card::before {
    content: "";
    position: absolute; left: 0; top: 0; bottom: 0;
    width: 3px; background: var(--accent);
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .player-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    box-shadow: 0 6px 16px rgba(214, 37, 56, 0.08), 0 2px 4px rgba(0,0,0,0.04);
    text-decoration: none;
  }
  .player-card:hover::before { opacity: 1; }
  .player-card:hover .go { color: var(--accent); transform: translateX(3px); }

  .card-head {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 0.7rem;
  }
  .head-tags { display: flex; gap: 0.35rem; }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
  }
  .tag.type { background: rgba(214, 37, 56, 0.08); color: var(--sv-red); border: 1px solid rgba(214, 37, 56, 0.2); }
  .tag.type.type-two_way { background: linear-gradient(90deg, rgba(214, 37, 56, 0.1), rgba(237, 124, 44, 0.1)); color: var(--sv-orange); border-color: rgba(237, 124, 44, 0.25); }
  .tag.league { background: var(--surface-3); color: var(--text-muted); border: 1px solid var(--border); }
  .tag.league.league-nl { color: var(--sv-blue); border-color: rgba(44, 93, 209, 0.25); background: rgba(44, 93, 209, 0.06); }
  .tag.league.league-al { color: var(--sv-red); border-color: rgba(214, 37, 56, 0.25); background: rgba(214, 37, 56, 0.06); }
  .tag.league.league-aaa { color: var(--sv-orange); border-color: rgba(237, 124, 44, 0.3); background: rgba(237, 124, 44, 0.08); }
  .tag.league.former { color: var(--text-muted); background: var(--surface-3); border-color: var(--border-strong); }
  .tag.no-current {
    color: var(--sv-orange);
    background: rgba(237, 124, 44, 0.1);
    border: 1px solid rgba(237, 124, 44, 0.3);
  }

  .go {
    color: var(--text-dim);
    font-family: var(--font-mono);
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .card-name {
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.015em;
    line-height: 1.1;
    margin-bottom: 0.35rem;
  }
  .card-meta {
    display: flex; gap: 0.4rem; align-items: center;
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-bottom: 1.1rem;
  }
  .sep { color: var(--text-dim); }

  .card-stats {
    display: flex; gap: 1.2rem;
    padding: 0.8rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .card-no-stats {
    padding: 0.85rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    text-align: center;
    font-size: 0.82rem;
    color: var(--sv-orange);
    font-weight: 500;
    background: rgba(237, 124, 44, 0.04);
    border-radius: var(--radius-sm);
  }
  .stat { display: flex; flex-direction: column; gap: 0.15rem; }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }
  .stat-value {
    font-family: var(--font-mono);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
    font-feature-settings: "tnum" 1;
  }

  .card-spark {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    padding-top: 0.75rem;
  }
  .spark-item {
    display: flex; flex-direction: column; gap: 0.1rem;
    align-items: flex-start;
  }
  .spark-lbl {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
  }
  .spark-val {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
  }

  @media (max-width: 640px) {
    .card-name { font-size: 1.35rem; }
    .card-stats { gap: 0.9rem; }
  }
</style>
